---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import LogoBar from "../components/LogoBar.astro";
import StatsBar from "../components/StatsBar.astro";
import QualifierSection from "../components/QualifierSection.astro";
import DelegationGrid from "../components/DelegationGrid.astro";
import ProcessSteps from "../components/ProcessSteps.astro";
import CaseStudy from "../components/CaseStudy.astro";
import ComparisonTable from "../components/ComparisonTable.astro";
import IndustryExpertise from "../components/IndustryExpertise.astro";
import TestimonialCard from "../components/TestimonialCard.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";

const base = import.meta.env.BASE_URL;
---

<Layout title="Leigh-Ann Martin | Fractional Executive Assistant and Chief of Staff">
  <Header />
  <main>
    <!-- Hero -->
    <section class="relative min-h-[85vh] flex items-center bg-primary overflow-hidden">
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>

      <div class="relative max-w-5xl mx-auto px-6 pt-28 pb-20 md:pt-36 md:pb-28 grid md:grid-cols-12 gap-10 md:gap-12 items-center">
        <!-- Photo -->
        <div class="md:col-span-4 flex justify-center md:justify-start">
          <div class="relative">
            <div class="absolute -inset-2 rounded-2xl border border-white/10"></div>
            <div class="w-48 h-48 md:w-56 md:h-56 rounded-2xl overflow-hidden ring-1 ring-white/10 shadow-2xl">
              <img
                src={`${base}leigh-ann.jpg`}
                alt="Leigh-Ann Martin"
                class="w-full h-full object-cover"
              />
            </div>
            <!-- LinkedIn link near photo -->
            <a href="https://linkedin.com/in/leigh-ann-martin" target="_blank" rel="noopener noreferrer" class="absolute -bottom-3 left-1/2 -translate-x-1/2 inline-flex items-center gap-1.5 bg-white/10 backdrop-blur-sm border border-white/15 rounded-full px-3 py-1.5 text-white/60 hover:text-white/90 transition-colors text-xs">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              LinkedIn
            </a>
          </div>
        </div>

        <!-- Text -->
        <div class="md:col-span-8">
          <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/10 rounded-full px-4 py-1.5 mb-6">
            <span class="w-2 h-2 rounded-full bg-secondary animate-pulse"></span>
            <span class="text-white/70 text-xs font-medium tracking-widest uppercase">Taking on 1 new client</span>
          </div>

          <h1 class="font-serif text-3xl md:text-4xl lg:text-5xl text-white leading-[1.15] mb-6">
            Your board prep is last-minute. Your investors are waiting. You're still
            <span class="text-secondary">doing it all yourself.</span>
          </h1>

          <p class="text-white/55 text-base md:text-lg leading-relaxed mb-8 max-w-xl">
            I was EA to the CEO of a pre-IPO biotech for 5 years. I managed 200+ investor relationships across 7 markets for a $562M publicly traded company. I ran audit-season operations at PwC. Now I do it fractionally for leaders who need a strategic operator, not a scheduler.
          </p>

          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href={`${base}contact`}
              class="inline-flex items-center justify-center gap-2 bg-secondary text-white px-7 py-3 rounded-full text-sm font-semibold hover:bg-secondary/90 transition-all shadow-lg shadow-secondary/20"
            >
              Book a Consultation
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a
              href={`${base}services`}
              class="inline-flex items-center justify-center gap-2 text-white/60 px-7 py-3 rounded-full text-sm font-medium border border-white/15 hover:border-white/30 hover:text-white/80 transition-all"
            >
              View Services
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Company Logo Bar -->
    <LogoBar />

    <!-- Results By The Numbers -->
    <StatsBar />

    <!-- Pain Points -->
    <section class="py-16 md:py-24 bg-cream">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-12" data-reveal>
          <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-secondary mb-4">Sound Familiar?</p>
          <h2 class="font-serif text-3xl md:text-4xl text-primary leading-tight">
            The problems I solve
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-6" data-reveal-stagger>
          <!-- Pain 1: Board governance -->
          <div class="bg-white rounded-2xl shadow-sm border border-primary/[0.06] p-7">
            <div class="w-10 h-10 bg-secondary/10 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2"/></svg>
            </div>
            <h3 class="font-serif text-lg text-primary mb-2">Board governance is reactive, not proactive</h3>
            <p class="text-text-muted text-sm leading-relaxed mb-3">Materials get assembled the night before. There's no repeatable prep process, no action tracking, no committee briefings. You're presenting to your board with duct tape behind the slides.</p>
            <p class="text-primary/70 text-sm leading-relaxed font-medium">Your board members notice. Your investors notice more. Sloppy governance signals sloppy leadership, and that's not who you are.</p>
          </div>

          <!-- Pain 2: Investor relationships going cold -->
          <div class="bg-white rounded-2xl shadow-sm border border-primary/[0.06] p-7">
            <div class="w-10 h-10 bg-secondary/10 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
            </div>
            <h3 class="font-serif text-lg text-primary mb-2">Investor relationships are going cold</h3>
            <p class="text-text-muted text-sm leading-relaxed mb-3">You closed the round, but nobody is managing the ongoing relationship. Quarterly updates go out late. Stakeholders are pinging you directly because there's no system.</p>
            <p class="text-primary/70 text-sm leading-relaxed font-medium">The relationships you worked hardest to build are eroding through neglect. Not because you don't care, but because nobody owns the follow-through.</p>
          </div>

          <!-- Pain 3: Institutional knowledge loss -->
          <div class="bg-white rounded-2xl shadow-sm border border-primary/[0.06] p-7">
            <div class="w-10 h-10 bg-secondary/10 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            </div>
            <h3 class="font-serif text-lg text-primary mb-2">Leadership transitions destroy institutional knowledge</h3>
            <p class="text-text-muted text-sm leading-relaxed mb-3">When your last EA or CoS left, 6 months of context walked out the door. No playbooks, no process docs, no onboarding systems. Every transition starts from scratch.</p>
            <p class="text-primary/70 text-sm leading-relaxed font-medium">The cost isn't just a bad quarter. It's 3 months of operational chaos while the new person figures out how things actually work.</p>
          </div>

          <!-- Pain 4: Multi-entity coordination -->
          <div class="bg-white rounded-2xl shadow-sm border border-primary/[0.06] p-7">
            <div class="w-10 h-10 bg-secondary/10 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <h3 class="font-serif text-lg text-primary mb-2">Multi-entity operations are a coordination nightmare</h3>
            <p class="text-text-muted text-sm leading-relaxed mb-3">Cross-functional meetings take 5 days to schedule. Nothing is standardized across locations or entities. Compliance gaps keep emerging because nobody owns the connective tissue.</p>
            <p class="text-primary/70 text-sm leading-relaxed font-medium">You need someone who has coordinated across 46 locations in 7 states for a publicly traded company. Not someone learning on the job.</p>
          </div>

          <!-- Pain 5: Trust & Confidentiality (full-width) -->
          <div class="bg-white rounded-2xl shadow-sm border border-primary/[0.06] p-7 md:col-span-2">
            <div class="md:flex md:items-start md:gap-6">
              <div class="w-10 h-10 bg-secondary/10 rounded-lg flex items-center justify-center mb-4 md:mb-0 flex-shrink-0">
                <svg class="w-5 h-5 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
              </div>
              <div>
                <h3 class="font-serif text-lg text-primary mb-2">You need someone you can trust with everything</h3>
                <p class="text-text-muted text-sm leading-relaxed mb-3">Board politics, investor negotiations, compensation data, M&A discussions, restructuring plans. The single biggest anxiety about bringing in an outside person is discretion. One slip and the damage is irreversible.</p>
                <p class="text-primary/70 text-sm leading-relaxed font-medium">I've handled board-level confidential matters for 12 years across regulated industries: biotech during FDA reviews, cannabis during multi-state compliance audits, Big Four during audit season. Every engagement starts with a mutual NDA. Discretion isn't a feature. It's the foundation.</p>
              </div>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- Qualifier: Is This You? -->
    <QualifierSection />

    <!-- What You Can Hand Off -->
    <DelegationGrid />

    <!-- How It Works -->
    <ProcessSteps />

    <!-- Case Studies -->
    <CaseStudy />

    <!-- Comparison Table -->
    <ComparisonTable />

    <!-- Industry Expertise -->
    <IndustryExpertise />

    <!-- Services Overview -->
    <section class="py-16 md:py-24 bg-warm">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-12" data-reveal>
          <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-secondary mb-4">Services</p>
          <h2 class="font-serif text-3xl md:text-4xl text-primary leading-tight">
            Three ways to work together
          </h2>
          <p class="text-text-muted text-base mt-4">
            Monthly retainers designed for different levels of executive support.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-6" data-reveal-stagger>
          <!-- Tier 1 -->
          <a href={`${base}services`} class="bg-white rounded-2xl shadow-sm border border-primary/[0.06] p-7 flex flex-col hover:shadow-md transition-shadow group">
            <p class="text-secondary text-xs font-semibold tracking-wide uppercase mb-2">Tier 1</p>
            <h3 class="font-serif text-xl text-primary mb-1 group-hover:text-secondary transition-colors">Executive Operations Partner</h3>
            <p class="font-serif text-3xl text-primary mb-3">$5,000<span class="text-text-muted text-sm font-sans">/mo</span></p>
            <p class="text-text-muted text-sm leading-relaxed flex-1">Calendar architecture, inbox triage, travel coordination, meeting prep. Your week runs itself.</p>
            <p class="text-secondary text-sm font-medium mt-4 flex items-center gap-1">
              Learn more
              <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </p>
          </a>

          <!-- Tier 2 -->
          <a href={`${base}services`} class="bg-white rounded-2xl shadow-md border-2 border-secondary p-7 flex flex-col relative hover:shadow-lg transition-shadow group">
            <div class="absolute -top-3 left-1/2 -translate-x-1/2">
              <span class="bg-secondary text-white text-xs font-bold px-4 py-1 rounded-full">Recommended</span>
            </div>
            <p class="text-secondary text-xs font-semibold tracking-wide uppercase mb-2">Tier 2</p>
            <h3 class="font-serif text-xl text-primary mb-1 group-hover:text-secondary transition-colors">Strategic Executive Partner</h3>
            <p class="font-serif text-3xl text-primary mb-3">$8,500<span class="text-text-muted text-sm font-sans">/mo</span></p>
            <p class="text-text-muted text-sm leading-relaxed flex-1">Everything in Tier 1, plus board prep, investor correspondence, project coordination, and executive onboarding.</p>
            <p class="text-secondary text-sm font-medium mt-4 flex items-center gap-1">
              Learn more
              <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </p>
          </a>

          <!-- Tier 3 -->
          <a href={`${base}services`} class="bg-white rounded-2xl shadow-sm border border-primary/[0.06] p-7 flex flex-col hover:shadow-md transition-shadow group">
            <p class="text-secondary text-xs font-semibold tracking-wide uppercase mb-2">Tier 3</p>
            <h3 class="font-serif text-xl text-primary mb-1 group-hover:text-secondary transition-colors">Fractional Chief of Staff</h3>
            <p class="font-serif text-3xl text-primary mb-3">$12,500<span class="text-text-muted text-sm font-sans">/mo</span></p>
            <p class="text-text-muted text-sm leading-relaxed flex-1">You focus on the vision. Everything else is handled. OKRs, confidential projects, hiring coordination, and on-call support.</p>
            <p class="text-secondary text-sm font-medium mt-4 flex items-center gap-1">
              Learn more
              <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </p>
          </a>
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="py-16 md:py-24 bg-cream">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-12" data-reveal>
          <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-secondary mb-4">What People Say</p>
          <h2 class="font-serif text-3xl md:text-4xl text-primary leading-tight">
            Trusted by executives and teams
          </h2>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6" data-reveal-stagger>
          <TestimonialCard
            quote="What I have with Leigh-Ann isn't a traditional EA relationship. It's a strategic partnership. She anticipates what I need before I know I need it, and she operates at a level that lets me focus entirely on the science and the business."
            attribution="CEO, Clinical-Stage Biopharma"
            context="5-year strategic partnership"
          />
          <TestimonialCard
            quote="She took over investor relations for a $562M publicly traded company and within weeks, response times dropped from days to hours. Our investors noticed. Our board noticed. I got 15 hours a month back."
            attribution="Executive Leader, Cannabis MSO"
            context="Investor relations across 7 markets"
          />
          <TestimonialCard
            quote="The onboarding system she created cut our executive ramp-up time by 20%. New leaders hit the ground running instead of spending their first month figuring out how things work."
            attribution="VP Operations, Financial Services"
            context="Executive onboarding systems"
          />
          <TestimonialCard
            quote="The board changed our meeting date with 48 hours notice. She delivered the complete materials package 4 hours early. That's not admin work. That's operational excellence under pressure."
            attribution="Board Member, Biopharma"
            context="Crisis board delivery"
          />
        </div>

        <p class="text-center text-text-muted text-sm mt-10" data-reveal>
          References provided during consultation.
        </p>
      </div>
    </section>

    <!-- Guarantee -->
    <section class="py-10 bg-warm border-y border-primary/[0.06]">
      <div class="max-w-2xl mx-auto px-6 text-center" data-reveal>
        <p class="text-secondary text-xs font-bold tracking-[0.2em] uppercase mb-3">Zero Risk</p>
        <p class="text-primary font-serif text-xl mb-3">Start with a project. No long-term lock-in.</p>
        <p class="text-text-muted text-sm leading-relaxed">The Operations Audit ($4,000) is designed to be the first step. You get a full assessment, a prioritized playbook, and a sense of how we work together. Many retainer clients started there. Retainers are month-to-month after the first 90 days.</p>
      </div>
    </section>

    <!-- CTA -->
    <CTA heading="I work with 3-4 clients at a time." subtext="If you need senior-level executive operations support without a full-time hire, let's talk. Book a free 30-minute call. No pitch, no pressure." />
  </main>
  <Footer />
</Layout>

<script>
  const revealEls = document.querySelectorAll("[data-reveal], [data-reveal-stagger]");
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("revealed");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: "0px 0px -60px 0px" }
  );
  revealEls.forEach((el) => observer.observe(el));
</script>
