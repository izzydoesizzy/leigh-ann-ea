// Status key:
//   live         = recommendation already posted on LinkedIn
//   sent         = email sent, awaiting response
//   ready        = draft ready to send, contact + email confirmed
//   needs-info   = draft ready, but contact info (email or last name) still being gathered
//   draft-needed = fresh draft required, no template reuse
//   second-tier  = send if priorities above respond well

type Status = "live" | "sent" | "ready" | "needs-info" | "draft-needed" | "second-tier";

interface Contact {
  name: string;
  title: string;
  company: string;
  status: Status;
  priority: "P1" | "P2" | "P3";
  linkedin: string | null;
  relationship: string;
  email: string;
  emailNote?: string;
  recommendation: string;
  emailSubject: string;
  emailBody: string;
  statusNote?: string;
}

