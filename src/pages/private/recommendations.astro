---
import Layout from "../../layouts/Layout.astro";
import PrivateHeader from "../../components/PrivateHeader.astro";
import Footer from "../../components/Footer.astro";

const base = import.meta.env.BASE_URL;

const linkedinRecommendationUrl = "https://www.linkedin.com/in/leigh-ann-martin/edit/forms/recommendation/write";

const contacts = [
  {
    name: "Dr. Pete Salzmann",
    title: "Former CEO",
    company: "Immunovant",
    linkedin: "https://www.linkedin.com/in/pete-salzmann-md",
    relationship: "Leigh-Ann was Pete's Senior Executive Assistant for ~5 years, supporting him through clinical-stage transitions, board governance, and investor relations.",
    email: "pete.salzmann@immunovant.com",
    altEmails: [],
    recommendation: `Leigh-Ann supported me for five years at Immunovant through some of the most operationally demanding phases a biotech CEO faces. She improved our executive decision-making effectiveness by 30% by implementing structured problem-solving and change management frameworks that replaced the ad hoc processes we had been relying on. She built onboarding and development programs for 6 administrative professionals, cutting ramp-up time by 20%. She also founded and led our internal Culture Committee, spearheading DEI workshops, employee wellness programs, and hybrid connectivity initiatives that measurably improved employee satisfaction scores by 22%. What set her apart was not just execution but anticipation. During clinical-stage transitions, she kept everything running before I had to ask. I would recommend her without hesitation to any CEO who needs a true strategic partner, not just an assistant.`,
    emailSubject: "A favor I've been meaning to ask",
    emailBody: `Hi Pete,

I hope you're doing well. I've been thinking about our time working together at Immunovant, and I wanted to ask you something.

I'm building my fractional executive support practice and LinkedIn recommendations from people I've worked closely with would mean a lot. You saw my work firsthand for five years, and a recommendation from you would carry real weight.

I know writing these from scratch can be a pain, so I drafted something below based on our work together. You're welcome to use it as-is, edit it to match your voice, or write something completely different. Whatever feels right.

Here's the draft:

---

"Leigh-Ann supported me for five years at Immunovant through some of the most operationally demanding phases a biotech CEO faces. She improved our executive decision-making effectiveness by 30% by implementing structured problem-solving and change management frameworks that replaced the ad hoc processes we had been relying on. She built onboarding and development programs for 6 administrative professionals, cutting ramp-up time by 20%. She also founded and led our internal Culture Committee, spearheading DEI workshops, employee wellness programs, and hybrid connectivity initiatives that measurably improved employee satisfaction scores by 22%. What set her apart was not just execution but anticipation. During clinical-stage transitions, she kept everything running before I had to ask. I would recommend her without hesitation to any CEO who needs a true strategic partner, not just an assistant."

---

Here's the direct link to leave the recommendation on LinkedIn:
${linkedinRecommendationUrl}

No pressure at all. I appreciate you either way.

Warmly,
Leigh-Ann`
  },
  {
    name: "Renee Barnett",
    title: "Former CFO",
    company: "Immunovant",
    linkedin: "https://www.linkedin.com/in/renee-barnett",
    relationship: "Leigh-Ann worked closely with Renee on financial reporting, board materials, investor communications, and SEC filing coordination during their overlapping tenure at Immunovant (2021-2024).",
    email: "renee.barnett@immunovant.com",
    altEmails: [],
    recommendation: `I worked alongside Leigh-Ann for several years at Immunovant, and she was one of the most reliable operational partners I've had. As CFO, I depended on precise coordination for board materials, quarterly reporting, and investor communications. Leigh-Ann enhanced our reporting accuracy by 25% by utilizing advanced analytics tools to translate executive vision into actionable operational initiatives. She partnered across HR, Facilities, and our Executive Leadership Team to modernize policies and implement hybrid work frameworks that improved employee satisfaction scores by 22%. What impressed me most was her financial literacy. She didn't just move documents around. She understood what was in them, flagged issues before they became problems, and brought structured problem-solving to high-level executive operations. Any executive team would be lucky to have her.`,
    emailSubject: "Quick request from a former Immunovant colleague",
    emailBody: `Hi Renee,

I hope all is well! I've been thinking about our time at Immunovant and wanted to reach out with a small ask.

I'm growing my fractional executive support business and building out my LinkedIn presence. A recommendation from you would mean a great deal, especially given how closely we worked on board materials, investor communications, and quarterly reporting.

I drafted something below to make it easy. Feel free to use it, adjust it, or write your own. Whatever works for you.

Here's the draft:

---

"I worked alongside Leigh-Ann for several years at Immunovant, and she was one of the most reliable operational partners I've had. As CFO, I depended on precise coordination for board materials, quarterly reporting, and investor communications. Leigh-Ann enhanced our reporting accuracy by 25% by utilizing advanced analytics tools to translate executive vision into actionable operational initiatives. She partnered across HR, Facilities, and our Executive Leadership Team to modernize policies and implement hybrid work frameworks that improved employee satisfaction scores by 22%. What impressed me most was her financial literacy. She didn't just move documents around. She understood what was in them, flagged issues before they became problems, and brought structured problem-solving to high-level executive operations. Any executive team would be lucky to have her."

---

Here's the direct link to leave the recommendation on LinkedIn:
${linkedinRecommendationUrl}

Thank you so much, Renee. I really appreciate it.

Warmly,
Leigh-Ann`
  },
  {
    name: "John Hartmann",
    title: "Former CEO",
    company: "Ascend Wellness Holdings",
    linkedin: "https://www.linkedin.com/in/johnhartmann",
    relationship: "Leigh-Ann served as EA and Investor Relations support to John during his tenure as CEO (2023-2024), managing operations across 7 markets and 48 retail locations.",
    email: "john.hartmann@awholdings.com",
    altEmails: [],
    recommendation: `Leigh-Ann supported me at Ascend Wellness Holdings during a period of significant growth. She served as the primary strategic liaison between the C-suite and 200+ internal and external stakeholders across 7 markets, achieving 98% satisfaction through proactive relationship management. She owned end-to-end calendar management with strategic prioritization, protecting executive focus and ensuring readiness for every meeting with full context and pre-work. She led quarterly board, committee, and investor relations operations, developing agile pre and post earnings plans that elevated cross-functional team preparedness. She also facilitated strategic alignment across M&A, IR, and our Executive Leadership Team, translating high-level vision into operational workflows that improved efficiency by 25%. In a fast-moving, heavily regulated environment, she never missed a beat.`,
    emailSubject: "A small favor, John",
    emailBody: `Hi John,

I hope the new chapter is going well. I wanted to reach out because I've been building my fractional executive support practice, and a LinkedIn recommendation from you would be incredibly valuable.

You saw firsthand what I brought to Ascend, from investor relations across 7 markets to board prep and stakeholder management. Your perspective on that work would mean a lot to prospective clients.

I've drafted something below to save you time. Feel free to use it, tweak it, or write something entirely your own.

Here's the draft:

---

"Leigh-Ann supported me at Ascend Wellness Holdings during a period of significant growth. She served as the primary strategic liaison between the C-suite and 200+ internal and external stakeholders across 7 markets, achieving 98% satisfaction through proactive relationship management. She owned end-to-end calendar management with strategic prioritization, protecting executive focus and ensuring readiness for every meeting with full context and pre-work. She led quarterly board, committee, and investor relations operations, developing agile pre and post earnings plans that elevated cross-functional team preparedness. She also facilitated strategic alignment across M&A, IR, and our Executive Leadership Team, translating high-level vision into operational workflows that improved efficiency by 25%. In a fast-moving, heavily regulated environment, she never missed a beat."

---

Here's the direct link to leave the recommendation on LinkedIn:
${linkedinRecommendationUrl}

No pressure at all. I appreciate everything, John.

Best,
Leigh-Ann`
  },
  {
    name: "Abner Kurtin",
    title: "Executive Chairman & Founder",
    company: "Ascend Wellness Holdings",
    linkedin: "https://www.linkedin.com/in/abnerkurtin",
    relationship: "Leigh-Ann worked with Abner in his capacity as founder and Executive Chairman, supporting board-level operations, governance, and investor relations.",
    email: "abner.kurtin@awholdings.com",
    altEmails: [],
    recommendation: `Leigh-Ann was a key part of our executive operations at Ascend Wellness Holdings from the time we were navigating post-IPO operations through our expansion to 46 locations across 7 states. As founder and Chairman, I needed someone who could handle board-level governance, investor relations, and compliance-sensitive communications for a company listed on both the CSE and OTCQX. Leigh-Ann managed those relationships across 200+ stakeholders with 98% satisfaction. What distinguished her was versatility. She came to us from five years supporting the CEO and General Counsel at a clinical-stage biotech, and before that from PwC. She understood board governance, regulatory cadence, and investor expectations from day one, with zero ramp-up time. She operates at the highest level.`,
    emailSubject: "Reaching out with a quick ask",
    emailBody: `Hi Abner,

I hope you're well. I wanted to reach out because I'm growing my fractional executive support practice and your perspective would carry a lot of weight.

Working with you at Ascend gave me the chance to support board operations and investor relations at a level I'm really proud of. A LinkedIn recommendation from you would help prospective clients understand the caliber of work I deliver.

I've put together a draft below to make it easy. Please feel free to use it as-is, adjust it, or write something in your own words.

Here's the draft:

---

"Leigh-Ann was a key part of our executive operations at Ascend Wellness Holdings from the time we were navigating post-IPO operations through our expansion to 46 locations across 7 states. As founder and Chairman, I needed someone who could handle board-level governance, investor relations, and compliance-sensitive communications for a company listed on both the CSE and OTCQX. Leigh-Ann managed those relationships across 200+ stakeholders with 98% satisfaction. What distinguished her was versatility. She came to us from five years supporting the CEO and General Counsel at a clinical-stage biotech, and before that from PwC. She understood board governance, regulatory cadence, and investor expectations from day one, with zero ramp-up time. She operates at the highest level."

---

Here's the direct link to leave the recommendation on LinkedIn:
${linkedinRecommendationUrl}

Thank you, Abner. I truly appreciate it.

Best,
Leigh-Ann`
  },
  {
    name: "Frank Perullo",
    title: "President & Co-Founder",
    company: "Ascend Wellness Holdings",
    linkedin: "https://www.linkedin.com/in/frankperullo",
    relationship: "Leigh-Ann worked with Frank across real estate expansion strategy, cross-functional coordination, and executive operations during the company's rapid growth phase.",
    email: "frank.perullo@awholdings.com",
    altEmails: [],
    recommendation: `Leigh-Ann was essential to keeping executive operations running at Ascend Wellness during our most intense growth phase, as we expanded from 30 to 46 retail locations across 7 states. She coordinated across departments during a period when cross-functional meetings used to take 5 days to schedule. She developed agile pre and post earnings operational plans and managed the investor relations calendar for a publicly traded company filing on both the Canadian Securities Exchange and OTCQX. What I valued most was her ability to work independently at a high level. You could hand Leigh-Ann a complex, multi-market project and trust that it would be executed flawlessly. She brings real strategic thinking to executive support, not just task management.`,
    emailSubject: "A favor from your former colleague",
    emailBody: `Hi Frank,

I hope things are going well. I wanted to reach out because I'm building my fractional executive support business, and a LinkedIn recommendation from someone who saw my work at Ascend up close would mean a lot.

You experienced firsthand how I managed cross-functional coordination, investor relations, and executive operations during that intense growth period. Your perspective would be really valuable.

I've drafted something below to save you the blank-page problem. Feel free to use it, edit it, or write something completely different.

Here's the draft:

---

"Leigh-Ann was essential to keeping executive operations running at Ascend Wellness during our most intense growth phase, as we expanded from 30 to 46 retail locations across 7 states. She coordinated across departments during a period when cross-functional meetings used to take 5 days to schedule. She developed agile pre and post earnings operational plans and managed the investor relations calendar for a publicly traded company filing on both the Canadian Securities Exchange and OTCQX. What I valued most was her ability to work independently at a high level. You could hand Leigh-Ann a complex, multi-market project and trust that it would be executed flawlessly. She brings real strategic thinking to executive support, not just task management."

---

Here's the direct link to leave the recommendation on LinkedIn:
${linkedinRecommendationUrl}

Thank you so much, Frank. I appreciate it.

Best,
Leigh-Ann`
  },
  {
    name: "Dan Neville",
    title: "Former CFO & Interim Co-CEO",
    company: "Ascend Wellness Holdings",
    linkedin: "https://www.linkedin.com/in/dan-neville-cpa",
    relationship: "Leigh-Ann worked closely with Dan on financial reporting, investor communications, and quarterly operations during the company's time as a publicly traded entity.",
    email: "dan.neville@awholdings.com",
    altEmails: [],
    recommendation: `Working with Leigh-Ann at Ascend Wellness was a genuinely positive experience. She led our comprehensive investor relations program, including quarterly earnings coordination and stakeholder communications across 7 markets. Before joining us, she had managed $10M+ monthly in payment processing operations at BearingPoint with 99% accuracy. That financial precision carried over. Quarterly reporting, board materials, compliance-sensitive filings. Everything was accurate, on time, and well-organized. For a publicly traded company navigating multi-state regulatory requirements across the CSE and OTCQX, that level of precision was essential. Leigh-Ann also brought emotional intelligence to the role. She understood the pressures facing the leadership team and found ways to reduce friction rather than add to it. I'd recommend her to any executive who needs a trusted operational partner.`,
    emailSubject: "Quick ask from Leigh-Ann",
    emailBody: `Hi Dan,

I hope you're doing well. I've been building my fractional executive support practice and wanted to ask if you'd be willing to write a brief LinkedIn recommendation for me.

We worked closely on the finance and investor relations side at Ascend, and your perspective on that work would be really meaningful to prospective clients.

I drafted something below to make it as easy as possible. Feel free to use it, change it, or write your own version.

Here's the draft:

---

"Working with Leigh-Ann at Ascend Wellness was a genuinely positive experience. She led our comprehensive investor relations program, including quarterly earnings coordination and stakeholder communications across 7 markets. Before joining us, she had managed $10M+ monthly in payment processing operations at BearingPoint with 99% accuracy. That financial precision carried over. Quarterly reporting, board materials, compliance-sensitive filings. Everything was accurate, on time, and well-organized. For a publicly traded company navigating multi-state regulatory requirements across the CSE and OTCQX, that level of precision was essential. Leigh-Ann also brought emotional intelligence to the role. She understood the pressures facing the leadership team and found ways to reduce friction rather than add to it. I'd recommend her to any executive who needs a trusted operational partner."

---

Here's the direct link to leave the recommendation on LinkedIn:
${linkedinRecommendationUrl}

Thank you, Dan. I really appreciate it.

Best,
Leigh-Ann`
  },
  {
    name: "David Gacom",
    title: "Former COO",
    company: "Ascend Wellness Holdings",
    linkedin: "https://www.linkedin.com/in/davidgacom",
    relationship: "Leigh-Ann partnered with David on operational coordination, supply chain logistics, and multi-state execution across Ascend's 48+ retail locations.",
    email: "david.gacom@awholdings.com",
    altEmails: [],
    recommendation: `Leigh-Ann was a standout operator at Ascend Wellness. As COO, I worked with her on the coordination side of a multi-state operation as we scaled from 30 to 46 retail locations across Illinois, Massachusetts, Michigan, New Jersey, Ohio, Pennsylvania, and Maryland. She built standardized cross-location communication protocols and operational procedure manuals that became the connective tissue between markets. She coordinated complex logistics across time zones, managed compliance tracking for each jurisdiction, and kept executive scheduling running smoothly during a period of rapid expansion. I was also impressed by her process-building instinct. She didn't just manage what existed. She created how-to guides and onboarding manuals that ensured operational continuity through team transitions. Cannabis is a volatile, heavily regulated industry, and Leigh-Ann navigated it with composure and professionalism that you don't often see.`,
    emailSubject: "A small request from Leigh-Ann",
    emailBody: `Hi David,

I hope everything is going well. I'm reaching out because I've been growing my fractional executive support practice, and a LinkedIn recommendation from you would be really helpful.

We worked together on the operations side at Ascend during a period of rapid expansion, and your perspective would carry a lot of credibility. I've put together a draft below to make it easy.

Feel free to use it as written, adjust it, or write something entirely your own. Whatever works for you.

Here's the draft:

---

"Leigh-Ann was a standout operator at Ascend Wellness. As COO, I worked with her on the coordination side of a multi-state operation as we scaled from 30 to 46 retail locations across Illinois, Massachusetts, Michigan, New Jersey, Ohio, Pennsylvania, and Maryland. She built standardized cross-location communication protocols and operational procedure manuals that became the connective tissue between markets. She coordinated complex logistics across time zones, managed compliance tracking for each jurisdiction, and kept executive scheduling running smoothly during a period of rapid expansion. I was also impressed by her process-building instinct. She didn't just manage what existed. She created how-to guides and onboarding manuals that ensured operational continuity through team transitions. Cannabis is a volatile, heavily regulated industry, and Leigh-Ann navigated it with composure and professionalism that you don't often see."

---

Here's the direct link to leave the recommendation on LinkedIn:
${linkedinRecommendationUrl}

Thank you so much, David. I appreciate it.

Best,
Leigh-Ann`
  }
];

// Build mailto links with proper encoding for Gmail
function buildMailtoLink(email: string, subject: string, body: string): string {
  const encodedSubject = encodeURIComponent(subject);
  const encodedBody = encodeURIComponent(body);
  return `mailto:${email}?subject=${encodedSubject}&body=${encodedBody}`;
}
---

<Layout noindex={true} title="Recommendation Requests | Leigh-Ann Martin">
  <PrivateHeader />
  <main>
    <!-- Hero -->
    <section class="bg-primary pt-28 pb-16 md:pt-36 md:pb-20">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-secondary mb-4">Internal</p>
        <h1 class="font-serif text-3xl md:text-4xl lg:text-5xl text-white leading-tight mb-6">
          LinkedIn Recommendation Requests
        </h1>
        <p class="text-white/55 text-base md:text-lg leading-relaxed max-w-xl mx-auto">
          Pre-drafted emails for requesting LinkedIn recommendations from former colleagues. Each includes a sample recommendation and a direct link to the LinkedIn form.
        </p>
        <div class="mt-6 inline-flex items-center gap-2 bg-white/10 border border-white/10 rounded-full px-4 py-2">
          <span class="text-white/60 text-xs">{contacts.length} contacts</span>
          <span class="text-white/20">|</span>
          <span class="text-white/60 text-xs">2 companies</span>
          <span class="text-white/20">|</span>
          <span class="text-white/60 text-xs">Click to draft in Gmail</span>
        </div>
      </div>
    </section>

    <!-- Immunovant Section -->
    <section class="py-12 md:py-16 bg-cream">
      <div class="max-w-4xl mx-auto px-6">
        <div class="flex items-center gap-3 mb-8" data-reveal>
          <div class="w-10 h-10 bg-secondary/10 rounded-full flex items-center justify-center flex-shrink-0">
            <span class="text-secondary text-sm font-bold">I</span>
          </div>
          <div>
            <h2 class="font-serif text-2xl text-primary"><a href="https://www.linkedin.com/company/immunovant" target="_blank" rel="noopener noreferrer" class="hover:text-secondary transition-colors">Immunovant</a></h2>
            <p class="text-text-muted text-sm">Biotech / Biopharma &middot; 5 years &middot; EA to the CEO</p>
          </div>
        </div>

        <div class="space-y-6">
          {contacts.filter(c => c.company === "Immunovant").map((contact) => (
            <div class="bg-white rounded-2xl shadow-sm border border-primary/[0.06] overflow-hidden" data-reveal>
              <!-- Header -->
              <div class="p-6 pb-4">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <h3 class="font-serif text-lg text-primary">{contact.linkedin ? <a href={contact.linkedin} target="_blank" rel="noopener noreferrer" class="hover:text-secondary transition-colors">{contact.name}</a> : contact.name}</h3>
                    <p class="text-secondary text-sm font-medium">{contact.title}, {contact.company}</p>
                    <p class="text-text-muted text-xs mt-1">{contact.relationship}</p>
                  </div>
                  <a
                    href={buildMailtoLink(contact.email, contact.emailSubject, contact.emailBody)}
                    class="inline-flex items-center gap-2 bg-secondary text-white px-5 py-2.5 rounded-full text-sm font-semibold hover:bg-secondary/90 transition-all shadow-sm flex-shrink-0"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                    Draft Email
                  </a>
                </div>
                <p class="text-text-muted/60 text-xs mt-2">{contact.email}</p>
              </div>

              <!-- Sample Recommendation -->
              <div class="mx-6 mb-6 bg-cream rounded-xl p-5">
                <p class="text-[10px] font-semibold tracking-[0.2em] uppercase text-secondary mb-3">Sample Recommendation ({contact.recommendation.length} chars)</p>
                <p class="text-text/80 text-sm leading-relaxed italic">"{contact.recommendation}"</p>
              </div>

              <!-- Email Preview -->
              <details class="border-t border-primary/[0.06]">
                <summary class="flex items-center justify-between p-5 text-text-muted text-sm cursor-pointer hover:bg-cream/50 transition-colors">
                  <span class="flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                    Preview full email
                  </span>
                  <svg class="w-4 h-4 faq-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-5 pb-5">
                  <div class="bg-cream rounded-lg p-4">
                    <p class="text-xs text-text-muted mb-1"><span class="font-semibold">To:</span> {contact.email}</p>
                    <p class="text-xs text-text-muted mb-3"><span class="font-semibold">Subject:</span> {contact.emailSubject}</p>
                    <div class="text-sm text-text/80 whitespace-pre-line leading-relaxed">{contact.emailBody}</div>
                  </div>
                </div>
              </details>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Ascend Wellness Section -->
    <section class="py-12 md:py-16 bg-warm">
      <div class="max-w-4xl mx-auto px-6">
        <div class="flex items-center gap-3 mb-8" data-reveal>
          <div class="w-10 h-10 bg-secondary/10 rounded-full flex items-center justify-center flex-shrink-0">
            <span class="text-secondary text-sm font-bold">A</span>
          </div>
          <div>
            <h2 class="font-serif text-2xl text-primary"><a href="https://www.linkedin.com/company/ascend-wellness-holdings" target="_blank" rel="noopener noreferrer" class="hover:text-secondary transition-colors">Ascend Wellness Holdings</a></h2>
            <p class="text-text-muted text-sm">Cannabis MSO &middot; EA, Investor Relations &middot; 48 retail locations, 7 markets</p>
          </div>
        </div>

        <div class="space-y-6">
          {contacts.filter(c => c.company === "Ascend Wellness Holdings").map((contact) => (
            <div class="bg-white rounded-2xl shadow-sm border border-primary/[0.06] overflow-hidden" data-reveal>
              <!-- Header -->
              <div class="p-6 pb-4">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <h3 class="font-serif text-lg text-primary">{contact.linkedin ? <a href={contact.linkedin} target="_blank" rel="noopener noreferrer" class="hover:text-secondary transition-colors">{contact.name}</a> : contact.name}</h3>
                    <p class="text-secondary text-sm font-medium">{contact.title}, {contact.company}</p>
                    <p class="text-text-muted text-xs mt-1">{contact.relationship}</p>
                  </div>
                  <a
                    href={buildMailtoLink(contact.email, contact.emailSubject, contact.emailBody)}
                    class="inline-flex items-center gap-2 bg-secondary text-white px-5 py-2.5 rounded-full text-sm font-semibold hover:bg-secondary/90 transition-all shadow-sm flex-shrink-0"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                    Draft Email
                  </a>
                </div>
                <p class="text-text-muted/60 text-xs mt-2">{contact.email}</p>
              </div>

              <!-- Sample Recommendation -->
              <div class="mx-6 mb-6 bg-warm rounded-xl p-5">
                <p class="text-[10px] font-semibold tracking-[0.2em] uppercase text-secondary mb-3">Sample Recommendation ({contact.recommendation.length} chars)</p>
                <p class="text-text/80 text-sm leading-relaxed italic">"{contact.recommendation}"</p>
              </div>

              <!-- Email Preview -->
              <details class="border-t border-primary/[0.06]">
                <summary class="flex items-center justify-between p-5 text-text-muted text-sm cursor-pointer hover:bg-warm/50 transition-colors">
                  <span class="flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                    Preview full email
                  </span>
                  <svg class="w-4 h-4 faq-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-5 pb-5">
                  <div class="bg-warm rounded-lg p-4">
                    <p class="text-xs text-text-muted mb-1"><span class="font-semibold">To:</span> {contact.email}</p>
                    <p class="text-xs text-text-muted mb-3"><span class="font-semibold">Subject:</span> {contact.emailSubject}</p>
                    <div class="text-sm text-text/80 whitespace-pre-line leading-relaxed">{contact.emailBody}</div>
                  </div>
                </div>
              </details>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- LinkedIn Link -->
    <section class="py-12 bg-primary">
