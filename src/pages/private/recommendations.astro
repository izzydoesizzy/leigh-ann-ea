// Status metadata for rendering
const statusMeta: Record<Status, { label: string; classes: string; order: number }> = {
  live: { label: "Live on LinkedIn", classes: "bg-emerald-100 text-emerald-700 border-emerald-200", order: 1 },
  sent: { label: "Sent, awaiting", classes: "bg-blue-100 text-blue-700 border-blue-200", order: 2 },
  "draft-needed": { label: "Fresh draft needed", classes: "bg-red-100 text-red-700 border-red-200", order: 3 },
  "needs-info": { label: "Needs email / info", classes: "bg-amber-100 text-amber-700 border-amber-200", order: 4 },
  ready: { label: "Ready to send", classes: "bg-secondary/15 text-secondary border-secondary/25", order: 5 },
  "second-tier": { label: "Second tier", classes: "bg-slate-200 text-slate-600 border-slate-300", order: 6 },
};

// Build mailto links with proper encoding for Gmail
function buildMailtoLink(email: string, subject: string, body: string): string {
  const safeEmail = email.startsWith("[") ? "" : email;
  const encodedSubject = encodeURIComponent(subject);
  const encodedBody = encodeURIComponent(body);
  return `mailto:${safeEmail}?subject=${encodedSubject}&body=${encodedBody}`;
}

const immunovantContacts = contacts.filter(c => c.company === "Immunovant")
  .sort((a, b) => statusMeta[a.status].order - statusMeta[b.status].order);
const ascendContacts = contacts.filter(c => c.company === "Ascend Wellness Holdings" || c.company === "Mattio Communications")
  .sort((a, b) => statusMeta[a.status].order - statusMeta[b.status].order);

const counts = {
  live: contacts.filter(c => c.status === "live").length,
  sent: contacts.filter(c => c.status === "sent").length,
  ready: contacts.filter(c => c.status === "ready").length,
  draftNeeded: contacts.filter(c => c.status === "draft-needed").length,
  needsInfo: contacts.filter(c => c.status === "needs-info").length,
  secondTier: contacts.filter(c => c.status === "second-tier").length,
};
