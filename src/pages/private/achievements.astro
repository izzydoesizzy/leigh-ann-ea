---
import Layout from "../../layouts/Layout.astro";
import PrivateHeader from "../../components/PrivateHeader.astro";
import Footer from "../../components/Footer.astro";

const base = import.meta.env.BASE_URL;

// Skill: write-achievements (2-column Achievement | Description table).
// Every metric is confirmed or reliably estimated from Leigh-Ann's intake transcripts.
// No em dashes anywhere on this page.
// Source order is chronological (oldest first); displayed in reverse-chronological order.

// Descriptions are HTML strings. Quantified tokens (numbers, dates, scopes) wrapped
// in <strong> so the reader's eye skims down a vertical ladder of metrics.
const rolesChronological = [
  {
    id: "petrotrin",
    company: "Petrotrin",
    title: "Admin Assistant, Office of the VP of Oil & Refining",
    dates: "Age 18 through September 2006 US migration",
    industry: "Trinidad state-owned vertically integrated oil company",
    achievements: [
      {
        label: "Career Origin",
        description:
          "Started corporate-track career at <strong>age 18</strong> at Petrotrin, Trinidad's state-owned oil company and <strong>largest employer</strong>, supporting the Office of the <strong>VP of Oil & Refining</strong>.",
      },
    ],
  },
  {
    id: "bearingpoint",
    company: "BearingPoint",
    title: "Administrative support, Finance / Treasury (NYC)",
    dates: "November 2007 through Chapter 11 wind-down",
    industry: "Management consulting (Chapter 11 bankruptcy)",
    achievements: [
      {
        label: "First US Corporate Role",
        description:
          "Supported <strong>4 finance leaders</strong> (VP, Treasurer, VP of Finance, plus one) at BearingPoint from <strong>November 2007</strong>, covering accounts payable, accounts receivable, and wire transfers.",
      },
      {
        label: "Chapter 11 Continuity",
        description:
          "Maintained finance-function continuity through BearingPoint's <strong>Chapter 11 wind-down</strong>, coordinating with offshore teams in <strong>India and the British Virgin Islands</strong>.",
      },
    ],
  },
  {
    id: "dgb",
    company: "DGB Management",
    title: "Virtual Assistant, Internal Operations",
    dates: "Overlapped BearingPoint wind-down through Rich & Tang",
    industry: "Real-estate / advisory services",
    achievements: [
      {
        label: "Process Reduction",
        description:
          "Built DGB Management's <strong>first centralized client database</strong> in Microsoft Access, cutting owner field-to-entry process time by <strong>approximately 30%</strong>.",
      },
      {
        label: "Project Delivery",
        description:
          "Supported data entry and client records through <strong>two landed projects</strong> (Downtown Brooklyn's Fulton Street Mall and Beacon, New York) during the firm's growth phase.",
      },
    ],
  },
  {
    id: "rt",
    company: "Rich & Tang",
    title: "Operations / Customer-Service Team Support",
    dates: "Pre-PwC return; ended in mass layoffs",
    industry: "Brokerage / client services",
    achievements: [
      {
        label: "Process Documentation",
        description:
          "Authored <strong>1 procedural management manual</strong> covering lockbox management, ops and customer-service workflows, and backup reception across a <strong>2-location brokerage</strong> (NY and NJ).",
      },
      {
        label: "Accuracy Improvement",
        description:
          "Improved broker correspondence accuracy by <strong>approximately 20%</strong> by introducing <strong>multi-stage QC</strong> on ad-hoc and quarterly broker distribution cycles.",
      },
    ],
  },
  {
    id: "pwc",
    company: "PwC",
    title: "Team Assistant, Indirect Tax and State/Income Franchise Tax, plus Thought Leadership",
    dates: "Multi-year tenure (approximately 2.5 to 3 years in Tax before Thought Leadership scope added)",
    industry: "Big 4 public accounting",
    achievements: [
      {
        label: "Multi-Team Support",
        description:
          "Supported <strong>2 tax teams</strong> (Indirect Tax and State/Income Franchise Tax) across the full <strong>associate-to-MD ladder</strong>, owning Time and Expense for <strong>every director and MD</strong>.",
      },
      {
        label: "Budget Tracking",
        description:
          "Stewarded PwC Thought Leadership's weekly budget-tracking workflow at <strong>3 purchase orders covering 500 companies</strong> via the formula-driven <strong>WHIP report</strong>.",
      },
      {
        label: "Mentorship",
        description:
          "Mentored and onboarded <strong>4 incoming PwC team assistants</strong> outside the formal program, co-creating department-specific onboarding materials.",
      },
      {
        label: "Peak Season Coverage",
        description:
          "Delivered reliable coverage across a <strong>9-month peak tax season</strong> (Jan to April extensions plus <strong>Sept 15, Oct 15, Nov 15</strong> deadlines), earning <strong>'invaluable'</strong> team designation.",
      },
    ],
  },
  {
    id: "thirdbridge",
    company: "Third Bridge",
    title: "Internal Firm Services EA, New York and London",
    dates: "Post-PwC, pre-Immunovant",
    industry: "Expert network consultancy",
    achievements: [
      {
        label: "Multi-Geography Support",
        description:
          "Supported <strong>3 executives</strong> across <strong>NY and London</strong> (MD Operations, Chief HR Officer, visiting President/Founder) by starting <strong>8am ET</strong> for London afternoon overlap.",
      },
      {
        label: "Hiring",
        description:
          "Hired <strong>1 NY admin</strong> (dual HR and sales support) at Third Bridge by co-authoring the JD with HR and serving on the interview panel during <strong>Texas-office HR buildout</strong>.",
      },
      {
        label: "Onboarding Manual",
        description:
          "Authored Third Bridge's <strong>first EA-function onboarding manual</strong>: office-manager backup, travel/expense policy, external-guest protocols, President/CEO NY-visit playbook.",
      },
      {
        label: "Budget Discipline",
        description:
          "Enforced <strong>ELT meeting budget discipline</strong> across <strong>NY and London</strong> via policy (no first class on under 5-hour flights, hotel-rate ceilings) plus prior-year-spend benchmarking.",
      },
    ],
  },
  {
    id: "imvt",
    company: "Immunovant",
    title: "Sole Executive Assistant, scaled to EA Team Lead",
    dates: "September 2019 onward",
    industry: "Pre-IPO clinical-stage biopharma",
    achievements: [
      {
        label: "Early Employee",
        description:
          "Joined as <strong>employee #17 to 19</strong> at pre-IPO biopharma Immunovant in <strong>Sept 2019</strong>; scaled sole-EA coverage from <strong>1 to 5 C-suite execs</strong> (CEO, GC, CMO, CFO, CTDO) by <strong>March 2020</strong>.",
      },
      {
        label: "Function Buildout",
        description:
          "Built the Immunovant EA function <strong>from zero to a multi-person team</strong> by championing EA visibility in CEO 1:1s and securing low-cost L&D access from HR.",
      },
      {
        label: "Decision Velocity",
        description:
          "Accelerated Immunovant ELT and SLT decision velocity by <strong>approximately 30%</strong> (per <strong>CEO reviews</strong>) through hiring, calendar pre-staging, and cross-functional follow-through.",
      },
      {
        label: "Culture Committee",
        description:
          "Co-founded the Immunovant Culture Committee with HR: <strong>6 to 10 members</strong> on a <strong>6-month rotation</strong>, charter aligned to <strong>company KPIs</strong>, standing budget, post-event survey program.",
      },
      {
        label: "Onboarding Ramp",
        description:
          "Reduced Immunovant EA new-hire ramp from a <strong>6 to 8 week baseline</strong> via a centralized tabs-in-spreadsheets knowledge base, buddy pairings, and weekly all-EA syncs.",
      },
      {
        label: "FDA Coordination",
        description:
          "Coordinated <strong>FDA meeting readiness</strong> for Immunovant's regulatory team: CEO/CMO/GC prep, <strong>fireproof lockbox</strong> for hardcopy correspondence, <strong>clinical-trial ad-boards</strong>.",
      },
      {
        label: "Investor Relations",
        description:
          "Ran <strong>pre-IPO investor-relations coordination</strong> with the IR manager: press releases, earnings, no-deal roadshows, and <strong>CEO and CFO calendar ownership</strong> for investor meetings.",
      },
      {
        label: "Stakeholder Management",
        description:
          "Preserved a <strong>bi-weekly ELT meeting</strong> through a <strong>high-friction General Counsel</strong> relationship by personally owning agenda, spreadsheet updates, and SLT follow-ups.",
      },
    ],
  },
  {
    id: "ascend",
    company: "Ascend Wellness Holdings (AWH)",
    title: "Executive Assistant, Investor Relations",
    dates: "January 2025 to January 2026",
    industry: "Public cannabis operator, CSE and OTCQX-listed, 7 states",
    achievements: [
      {
        label: "Multi-State Coordination",
        description:
          "Coordinated ELT, SLT, HR, and legal stakeholders across a <strong>7-state public cannabis operator</strong> (NJ, PA, IL, MA, MD, MI, OH) trading on <strong>CSE and OTCQX</strong>.",
      },
      {
        label: "Earnings System",
        description:
          "Rebuilt Ascend's earnings-call prep into a repeatable <strong>6 to 8 week system</strong> (launched <strong>July 2025</strong>, deployed <strong>Q2 2025</strong>), aligning IR, Legal, Finance, PR, and C-suite.",
      },
      {
        label: "Stakeholder Integration",
        description:
          "Eliminated after-the-fact earnings-prep rework at Ascend by granting the <strong>Chief Commercial Officer script access</strong> and pulling the <strong>VP of Marketing</strong> into live Q2 prep.",
      },
      {
        label: "Board Cadence",
        description:
          "Established Ascend's <strong>first quarterly board-meeting cadence</strong> (<strong>zero on the calendar at hire</strong>) and planned the full 2026 board and committee calendar <strong>12 months ahead</strong>.",
      },
      {
        label: "Board Governance",
        description:
          "Coordinated Ascend's <strong>8-person quarterly board</strong> (<strong>4 external directors</strong> plus CEO, CFO, President, Chief Counsel) and <strong>2 standing committees</strong> (Audit and Compensation).",
      },
      {
        label: "M&A Elevation",
        description:
          "Elevated Ascend's <strong>weekly M&A meeting</strong> at <strong>CEO request</strong> by joining for executive presence, building a <strong>follow-up dashboard</strong>, and restructuring M&A's capture format.",
      },
      {
        label: "Chairman Trust",
        description:
          "Earned direct <strong>chairman-of-the-board trust</strong> at Ascend (personal phone number and text channel) across <strong>12 months</strong>, the basis for the <strong>98% stakeholder-satisfaction</strong> claim.",
      },
      {
        label: "Executive Development",
        description:
          "Vetted a <strong>public-speaking consultant</strong> for Ascend's CEO by screening candidates, scheduling <strong>multiple consultation meetings</strong>, and weighing development value against fee.",
      },
    ],
  },
];

const roles = rolesChronological.toReversed();
const totalAchievements = roles.reduce((sum, r) => sum + r.achievements.length, 0);
---

<Layout noindex={true} title="Achievements | Leigh-Ann Martin" description="Resume-ready quantified achievements across all 8 roles.">
  <PrivateHeader />
  <div class="md:ml-60">
  <main>
    <!-- Hero -->
    <section class="bg-primary pt-24 pb-12 md:pt-16 md:pb-16">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-secondary mb-4">Achievements</p>
        <h1 class="font-serif text-3xl md:text-4xl text-white leading-tight mb-4">
          Resume-ready, quantified.
        </h1>
        <p class="text-white/50 text-base leading-relaxed max-w-xl mx-auto">
          Every quantified achievement from your intake transcripts in the 2-column Achievement / Description table the write-achievements skill produces. Copy straight into your resume, LinkedIn, or consulting proposal. {totalAchievements} achievements across {roles.length} roles.
        </p>
      </div>
    </section>

    <!-- Jump nav -->
    <section class="py-5 bg-cream border-b border-primary/[0.06]">
      <div class="max-w-4xl mx-auto px-6">
        <div class="flex flex-wrap gap-2 justify-start items-center">
          <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-text-muted mr-3">Jump to</p>
          {roles.map((r) => (
            <a
              href={`#${r.id}`}
              class="inline-block bg-white border border-primary/10 text-primary px-3 py-1.5 rounded-full text-xs font-medium hover:bg-primary hover:text-white transition-all"
            >
              {r.company}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Role-by-role tables -->
    <section id="tables" class="py-12 md:py-16 bg-cream">
      <div class="max-w-4xl mx-auto px-6">
        {roles.map((role, idx) => (
          <article id={role.id} class={`${idx > 0 ? "mt-12" : ""}`}>
            <header class="mb-5">
              <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-1 mb-1">
                <h2 class="font-serif text-2xl md:text-3xl text-primary leading-tight">{role.company}</h2>
                <p class="text-[11px] font-semibold uppercase tracking-wider text-secondary">{role.dates}</p>
              </div>
              <p class="text-primary/80 text-[15px] font-medium">{role.title}</p>
              <p class="text-text-muted text-sm mt-1">{role.industry}</p>
            </header>

            <div class="bg-white rounded-xl shadow-sm overflow-hidden border border-primary/[0.08]">
              <table class="w-full border-collapse">
                <thead>
                  <tr class="bg-cream/60 border-b border-primary/10">
                    <th class="text-left text-[11px] font-semibold tracking-[0.15em] uppercase text-primary py-3 px-5 w-[28%] align-top">Achievement</th>
                    <th class="text-left text-[11px] font-semibold tracking-[0.15em] uppercase text-primary py-3 px-5 align-top">Description</th>
                  </tr>
                </thead>
                <tbody>
                  {role.achievements.map((ach, i) => (
                    <tr class={i > 0 ? "border-t border-primary/[0.06]" : ""}>
                      <td class="py-4 px-5 align-top">
                        <p class="font-serif text-[15px] text-primary font-semibold leading-snug">{ach.label}</p>
                      </td>
                      <td class="py-4 px-5 align-top">
                        <p class="text-text text-[14px] leading-relaxed [&_strong]:text-primary [&_strong]:font-semibold" set:html={ach.description}></p>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- Source discipline -->
    <section class="py-16 bg-primary text-white">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-secondary mb-4">Source discipline</p>
        <h2 class="font-serif text-2xl md:text-3xl leading-tight mb-5">
          Every number traces back to your own words.
        </h2>
        <p class="text-white/75 leading-relaxed">
          Confirmed numbers are stated verbatim in your intake transcripts. Numbers marked "approximately" are estimates you made yourself in conversation with Izzy (30% DGB process reduction, 20% R&T accuracy gain, 30% Immunovant decision velocity, employee #17 to 19 at Immunovant). The 98% Ascend stakeholder-satisfaction claim on your consulting proposal is your own estimate based on chairman-of-the-board and ELT responsiveness, not a formal survey. Nothing on this page was invented.
        </p>
      </div>
    </section>

    <!-- Back to dashboard -->
    <section class="py-10 bg-cream">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <a href={`${base}private`} class="text-text-muted/50 text-xs hover:text-text-muted transition-colors">
          &larr; Back to dashboard
        </a>
      </div>
    </section>
  </main>
  <Footer />
  </div>
</Layout>
