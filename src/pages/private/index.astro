---
import Layout from "../../layouts/Layout.astro";
import PrivateHeader from "../../components/PrivateHeader.astro";
import Footer from "../../components/Footer.astro";

const base = import.meta.env.BASE_URL;

const sections = [
  {
    title: "Case Study Deep-Dive Questions",
    href: `${base}private/case-study-questions`,
    description: "Role-by-role questions designed to uncover the real metrics, stories, and impact behind your career. 65+ targeted questions across all 8 roles, plus cross-cutting themes. Record your answers via Otter before Session 2.",
    stats: "8 roles | 65+ questions | Metrics & impact | Testimonial language",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  },
  {
    title: "Getting Started",
    href: `${base}private/getting-started`,
    description: "Your step-by-step action plan. A 4-week phased approach covering interview closing skills, job applications, fractional outreach, LinkedIn DM strategies, follow-up cadences, and pipeline tracking.",
    stats: "4-week plan | 2 parallel tracks | DM templates | Pipeline tracker",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>`,
  },
  {
    title: "Prospect Database",
    href: `${base}private/prospects`,
    description: "26+ target companies across biotech, fintech, healthtech, cannabis, and cybersecurity. Each with CEO name, funding stage, outreach angle, recommended tier, and priority ranking.",
    stats: "26 companies | 5 industries | A/B priority tiers",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`,
  },
  {
    title: "Cold Outreach Emails",
    href: `${base}private/outreach`,
    description: "Personalized click-to-draft emails for every priority prospect. Each email has a custom subject line, industry-specific hook, and Leigh-Ann's credentials woven in naturally.",
    stats: "15+ emails | Click-to-draft mailto links | Gmail-ready",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
  },
  {
    title: "Job Opportunities",
    href: `${base}private/opportunities`,
    description: "Active EA and Chief of Staff job listings prioritized by fit. Includes salary ranges, application links, and custom strategy notes for each opportunity.",
    stats: "Priority A, B, C tiers | Direct application links",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
  },
  {
    title: "LinkedIn Recommendations",
    href: `${base}private/recommendations`,
    description: "Pre-drafted recommendation request emails for 7 former colleagues at Immunovant and Ascend Wellness. Each includes a ~500 character sample recommendation and a direct link to the LinkedIn form.",
    stats: "7 contacts | 2 companies | Click-to-draft emails",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>`,
  },
  {
    title: "Interview Prep Guide",
    href: `${base}private/interview-prep`,
    description: "Comprehensive 12-section interview preparation guide for EA roles in NYC. Covers role landscape, market intel, target companies, competitive edge, employer objections with counter-strategies, STAR stories, and a complete interview playbook.",
