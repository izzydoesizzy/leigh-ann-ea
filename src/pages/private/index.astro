  },
  {
    title: "Market Research",
    href: `${base}private/research`,
    description: "Deep research on the fractional EA market with 16 cited sources. Market size, CEO time studies, cost analysis, NYC salary data, board governance gaps, and AI adoption trends.",
    stats: "6 sections | 16 sources | Inline footnotes | Data tables",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
  },
];
---

<Layout noindex={true} title="Private Dashboard | Leigh-Ann Martin" description="Internal tools and resources for Leigh-Ann Martin's career launch.">
  <PrivateHeader />
  <main>
    <!-- Hero -->
    <section class="bg-primary pt-24 pb-12 md:pt-32 md:pb-16">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-secondary mb-4">Private Dashboard</p>
        <h1 class="font-serif text-3xl md:text-4xl text-white leading-tight mb-4">
          Your Career Launch Toolkit
        </h1>
        <p class="text-white/50 text-base leading-relaxed max-w-xl mx-auto">
          Everything built for your job search and fractional practice in one place. Prospect research, outreach emails, interview prep, and recommendation requests.
        </p>
      </div>
    </section>

    <!-- Cards -->
    <section class="py-12 md:py-16 bg-cream">
      <div class="max-w-4xl mx-auto px-6">
        <div class="space-y-4">
          {sections.map((section, i) => (
            <a
              href={section.href}
              class="block bg-white rounded-2xl shadow-sm border border-primary/[0.06] p-6 hover:shadow-md hover:border-secondary/20 transition-all group"
            >
              <div class="flex items-start gap-5">
                <div class="w-12 h-12 bg-secondary/10 rounded-xl flex items-center justify-center flex-shrink-0 text-secondary group-hover:bg-secondary group-hover:text-white transition-all">
                  <Fragment set:html={section.icon} />
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-start justify-between gap-4">
                    <h2 class="font-serif text-lg text-primary group-hover:text-secondary transition-colors">{section.title}</h2>
                    <svg class="w-5 h-5 text-text-muted/30 group-hover:text-secondary group-hover:translate-x-1 transition-all flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                  </div>
                  <p class="text-text-muted text-sm leading-relaxed mt-1">{section.description}</p>
                  <p class="text-text-muted/50 text-xs mt-3">{section.stats}</p>
                </div>
              </div>
            </a>
          ))}
        </div>

        <!-- Back to public site -->
        <div class="text-center mt-10">
          <a href={base} class="text-text-muted/40 text-xs hover:text-text-muted/60 transition-colors">
            Back to public site
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  const revealEls = document.querySelectorAll("[data-reveal], [data-reveal-stagger]");
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("revealed");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: "0px 0px -60px 0px" }
  );
  revealEls.forEach((el) => observer.observe(el));
</script>
