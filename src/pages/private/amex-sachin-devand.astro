---
import Layout from "../../layouts/Layout.astro";
import PrivateHeader from "../../components/PrivateHeader.astro";
import Footer from "../../components/Footer.astro";

const base = import.meta.env.BASE_URL;
---

<Layout noindex={true} title="Amex / Sachin Devand Interview Prep | Leigh-Ann Martin" description="Friday screening prep for Senior EA to Sachin Devand at American Express.">
  <PrivateHeader />
  <div class="md:ml-60">
  <main>
    <!-- Hero -->
    <section class="bg-primary pt-24 pb-12 md:pt-16 md:pb-16">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-secondary mb-4">Friday Screening Prep</p>
        <h1 class="font-serif text-3xl md:text-4xl text-white leading-tight mb-4">
          Senior EA to Sachin Devand
          <span class="block text-white/55 text-2xl md:text-3xl mt-2">American Express</span>
        </h1>
        <p class="text-white/55 text-base leading-relaxed max-w-xl mx-auto mb-6">
          Friday 2026-05-22 at 1pm with Kevin Murray. A deep dossier with tactics, scripts, and a Friday-morning cheat card. Read once, scan often.
        </p>
        <div class="flex flex-wrap justify-center gap-2">
          <span class="bg-white/10 border border-white/10 text-white/60 text-xs px-3 py-1 rounded-full">Fri 1pm</span>
          <span class="bg-white/10 border border-white/10 text-white/60 text-xs px-3 py-1 rounded-full">4 days in-office</span>
          <span class="bg-white/10 border border-white/10 text-white/60 text-xs px-3 py-1 rounded-full">Referral: Sai</span>
          <span class="bg-white/10 border border-white/10 text-white/60 text-xs px-3 py-1 rounded-full">Treat it like a $150K client pitch</span>
        </div>
      </div>
    </section>

    <!-- Quick Nav -->
    <section class="bg-primary/95 border-t border-white/[0.06] py-4 sticky top-14 md:top-0 z-40">
      <div class="max-w-4xl mx-auto px-6">
        <div class="flex flex-wrap justify-center gap-2 text-xs">
          <a href="#cheat-card" class="text-white/40 hover:text-white/70 transition-colors">Cheat Card</a>
          <span class="text-white/15">|</span>
          <a href="#truth-legend" class="text-white/40 hover:text-white/70 transition-colors">Legend</a>
          <span class="text-white/15">|</span>
          <a href="#sachin" class="text-white/40 hover:text-white/70 transition-colors">1. Sachin</a>
          <span class="text-white/15">|</span>
          <a href="#sachin-presence" class="text-white/40 hover:text-white/70 transition-colors">2. Web Presence</a>
          <span class="text-white/15">|</span>
          <a href="#sachin-linkedin" class="text-white/40 hover:text-white/70 transition-colors">3. LinkedIn</a>
          <span class="text-white/15">|</span>
          <a href="#sachin-work" class="text-white/40 hover:text-white/70 transition-colors">4. Articles</a>
          <span class="text-white/15">|</span>
          <a href="#team" class="text-white/40 hover:text-white/70 transition-colors">5. Team</a>
          <span class="text-white/15">|</span>
          <a href="#initiatives" class="text-white/40 hover:text-white/70 transition-colors">6. Initiatives</a>
          <span class="text-white/15">|</span>
          <a href="#role" class="text-white/40 hover:text-white/70 transition-colors">7. The Role</a>
          <span class="text-white/15">|</span>
          <a href="#referral" class="text-white/40 hover:text-white/70 transition-colors">8. Referral</a>
          <span class="text-white/15">|</span>
          <a href="#reframe" class="text-white/40 hover:text-white/70 transition-colors">9. Reframe</a>
          <span class="text-white/15">|</span>
          <a href="#questions-to-ask" class="text-white/40 hover:text-white/70 transition-colors">10. Ask</a>
          <span class="text-white/15">|</span>
          <a href="#expected-q" class="text-white/40 hover:text-white/70 transition-colors">11. Expected Q&A</a>
          <span class="text-white/15">|</span>
          <a href="#star" class="text-white/40 hover:text-white/70 transition-colors">12. STAR</a>
          <span class="text-white/15">|</span>
          <a href="#objections" class="text-white/40 hover:text-white/70 transition-colors">13. Objections</a>
          <span class="text-white/15">|</span>
          <a href="#checklist" class="text-white/40 hover:text-white/70 transition-colors">14. Checklist</a>
          <span class="text-white/15">|</span>
          <a href="#followup" class="text-white/40 hover:text-white/70 transition-colors">15. Follow-Up</a>
          <span class="text-white/15">|</span>
          <a href="#salary" class="text-white/40 hover:text-white/70 transition-colors">16. Salary</a>
          <span class="text-white/15">|</span>
          <a href="#competitors" class="text-white/40 hover:text-white/70 transition-colors">17. Competitors</a>
        </div>
      </div>
    </section>

    <!-- Cheat Card -->
    <section id="cheat-card" class="py-12 md:py-16 bg-cream">
      <div class="max-w-3xl mx-auto px-6">
        <p class="text-secondary text-xs font-semibold tracking-[0.15em] uppercase mb-2">Friday Morning</p>
        <h2 class="font-serif text-2xl md:text-3xl text-primary mb-6">The TL;DR Cheat Card</h2>
        <p class="text-text-muted text-sm mb-6">If you only re-read one thing 30 minutes before the call, make it this card.</p>

        <div class="bg-white rounded-2xl shadow-sm border border-primary/[0.06] p-6 space-y-5">
          <div>
            <p class="text-[11px] font-semibold tracking-[0.15em] uppercase text-secondary mb-1">Who he is</p>
            <p class="text-primary text-sm leading-relaxed">Sachin Devand, EVP &amp; Unit CIO for US Consumer Services, Digital &amp; Enterprise Data at Amex. 25+ years in tech and digital. Prior: Groupon CTO, Marcus by Goldman Sachs, eBay, AHAlife, 33Across. IIT Bombay. Lives in Jersey City. Active on LinkedIn under <span class="font-medium">#teamamex #amextech #ai</span>. Featured in the Amex Tech post on the Platinum Card refresh.</p>
          </div>

          <div>
            <p class="text-[11px] font-semibold tracking-[0.15em] uppercase text-secondary mb-1">Your opener (after rapport)</p>
            <p class="text-primary text-sm italic leading-relaxed">"Before we dive in, I want you to know I've already started thinking about this role like I'm joining the team. I've spent time on Sachin's public work, the team's recent launches, and how a Senior EA at this level adds the most leverage. So if it's helpful, I'd love to share what I'm seeing and have you correct me where I'm off."</p>
          </div>

          <div>
            <p class="text-[11px] font-semibold tracking-[0.15em] uppercase text-secondary mb-1">3 questions to ask</p>
            <ol class="space-y-2 text-sm text-text-muted list-decimal list-inside">
              <li>"What does a great first 90 days look like for the EA, is it the calendar landing on its feet, or is it Sachin's first board / business-review cycle going smoothly?"</li>
              <li>"How does this EA work alongside the rest of Sachin's support, are there other EAs or coordinators on the team I'd be coordinating with?"</li>
              <li>"With the Platinum refresh and the AI/ML work, what's the rhythm of his week look like right now, mostly internal reviews, external partner time, or both?"</li>
            </ol>
          </div>

          <div>
            <p class="text-[11px] font-semibold tracking-[0.15em] uppercase text-secondary mb-1">3 stories to lead with</p>
            <ul class="space-y-2 text-sm text-text-muted">
              <li><span class="font-medium text-primary">Building Ascend's board cadence from zero</span>: you can stand up rhythm where there is none.</li>
              <li><span class="font-medium text-primary">Earnings prep system rebuild</span>: you build repeatable systems, not heroics.</li>
              <li><span class="font-medium text-primary">Onboarding 6 admin pros at Immunovant (20% ramp reduction)</span>: you can lead and manage other EAs, which Sai asked about.</li>
            </ul>
          </div>

          <div>
            <p class="text-[11px] font-semibold tracking-[0.15em] uppercase text-secondary mb-1">If FP&amp;A / chief-of-staff scope comes up</p>
            <p class="text-primary text-sm leading-relaxed">"I haven't held a financial planning title, so I won't oversell it. What I have done is run investor-relations support for a publicly traded operator at $562M revenue, earnings prep, board materials, audit and comp committees. I can build budgets, track variance, and translate them for an executive, but I'd want to be honest about where FP&amp;A specialists pick up."</p>
          </div>

          <div>
            <p class="text-[11px] font-semibold tracking-[0.15em] uppercase text-secondary mb-1">His public voice (match this energy)</p>
            <p class="text-primary text-sm leading-relaxed"><span class="font-medium">#teamamex #amextech #ai.</span> He celebrates teams publicly, name-checks colleagues, and talks about up-skilling tech talent in AI/ML. Recent themes: Platinum refresh, Stanford HAI partnership, cloud + automation, "consumer digital experiences powered by advanced technologies." Speak like a peer who's read his last 10 posts, because you have.</p>
          </div>

          <div>
            <p class="text-[11px] font-semibold tracking-[0.15em] uppercase text-secondary mb-1">Pacing reminder</p>
            <p class="text-primary text-sm leading-relaxed"><span class="font-medium">Slow down by a third.</span> Headline first. Pause for 2 seconds after big statements. Let it land.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Truth Legend -->
    <section id="truth-legend" class="py-10 md:py-12 bg-warm">
      <div class="max-w-3xl mx-auto px-6">
        <p class="text-secondary text-xs font-semibold tracking-[0.15em] uppercase mb-2">Read This Once</p>
        <h2 class="font-serif text-2xl text-primary mb-4">What's True vs. What We're Assuming</h2>
        <p class="text-text-muted text-sm mb-5">Every factual claim on this page carries one of these badges so you know which to drop in conversation with confidence and which to soft-pedal or verify with Sai on Friday morning.</p>
        <div class="bg-white rounded-2xl shadow-sm border border-primary/[0.06] p-6 space-y-3">
          <div class="flex items-start gap-3">
            <span class="inline-block bg-emerald-100 text-emerald-800 text-[10px] font-bold tracking-wider uppercase px-2 py-0.5 rounded mt-0.5 flex-shrink-0">Confirmed</span>
            <p class="text-text-muted text-sm">Sourced from the Fathom transcript of your prep call (2026-05-20), official Amex Technology pages, or Sachin's public LinkedIn. Safe to state plainly in the interview.</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="inline-block bg-amber-100 text-amber-800 text-[10px] font-bold tracking-wider uppercase px-2 py-0.5 rounded mt-0.5 flex-shrink-0">Likely</span>
            <p class="text-text-muted text-sm">Reasonable inference from public sources or the transcript, not directly stated. Use as a "my understanding is&hellip;" framing, then let the interviewer correct.</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="inline-block bg-rose-100 text-rose-800 text-[10px] font-bold tracking-wider uppercase px-2 py-0.5 rounded mt-0.5 flex-shrink-0">Assumed</span>
            <p class="text-text-muted text-sm">Unverified placeholder. Do <span class="font-medium">not</span> state as fact. Use these as topics to ask about, not claims to make. Verify with Sai's Friday-morning prep call.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 1. Sachin -->
    <section id="sachin" class="py-12 md:py-16 bg-cream">
      <div class="max-w-3xl mx-auto px-6">
        <p class="text-secondary text-xs font-semibold tracking-[0.15em] uppercase mb-2">Section 1</p>
        <h2 class="font-serif text-2xl md:text-3xl text-primary mb-6">Who You're Supporting: Sachin Devand</h2>

        <div class="bg-white rounded-2xl shadow-sm border border-primary/[0.06] p-6 mb-6">
          <h3 class="font-semibold text-primary text-base mb-3">The Headline</h3>
          <p class="text-text-muted text-sm leading-relaxed">
            Sachin Devand is the EVP &amp; Unit Chief Information Officer for US Consumer Services, Digital &amp; Enterprise Data at American Express
            <span class="inline-block bg-emerald-100 text-emerald-800 text-[10px] font-bold tracking-wider uppercase px-1.5 py-0.5 rounded ml-1">Confirmed</span>.
            He leads the engineering, digital, data, AI and ML organization that powers the consumer-facing experiences for the US Card business
            <span class="inline-block bg-emerald-100 text-emerald-800 text-[10px] font-bold tracking-wider uppercase px-1.5 py-0.5 rounded ml-1">Confirmed</span>.
            He joined Amex in late 2022 from Goldman Sachs's Marcus business
            <span class="inline-block bg-emerald-100 text-emerald-800 text-[10px] font-bold tracking-wider uppercase px-1.5 py-0.5 rounded ml-1">Confirmed</span>,
            and he likely sits in the chain of command under Howard Grosfield, Group President of US Consumer Services
            <span class="inline-block bg-amber-100 text-amber-800 text-[10px] font-bold tracking-wider uppercase px-1.5 py-0.5 rounded ml-1">Likely</span>.
          </p>
        </div>

        <h3 class="font-semibold text-primary text-lg mb-3">Career Arc</h3>
        <div class="overflow-x-auto mb-6">
          <table class="w-full text-sm bg-white rounded-xl shadow-sm overflow-hidden">
            <thead>
              <tr class="bg-primary/5">
                <th class="text-left text-primary font-semibold p-3 text-xs uppercase tracking-wide">Company</th>
                <th class="text-left text-primary font-semibold p-3 text-xs uppercase tracking-wide">Role</th>
                <th class="text-left text-primary font-semibold p-3 text-xs uppercase tracking-wide">What it tells you</th>
              </tr>
            </thead>
            <tbody class="text-text-muted">
              <tr class="border-t border-primary/[0.06]">
                <td class="p-3 font-medium text-primary">American Express<br/><span class="text-xs text-text-muted/70">Late 2022 &ndash; present</span></td>
                <td class="p-3">EVP, Unit CIO, US Consumer Services, Digital &amp; Enterprise Data</td>
                <td class="p-3">Top of the consumer-side tech org. Big public mandate around digital experience + AI.</td>
              </tr>
              <tr class="border-t border-primary/[0.06]">
                <td class="p-3 font-medium text-primary">Goldman Sachs<br/><span class="text-xs text-text-muted/70">Marcus</span></td>
                <td class="p-3">Senior tech leadership (Marcus consumer banking)</td>
                <td class="p-3">Built consumer digital products in regulated finance, same playbook he is running at Amex.</td>
              </tr>
              <tr class="border-t border-primary/[0.06]">
                <td class="p-3 font-medium text-primary">Groupon</td>
                <td class="p-3">CTO</td>
                <td class="p-3">Operator scale, global ecommerce platform.</td>
              </tr>
              <tr class="border-t border-primary/[0.06]">
                <td class="p-3 font-medium text-primary">eBay</td>
                <td class="p-3">Senior engineering leader</td>
                <td class="p-3">Marketplaces, payments, data at scale.</td>
              </tr>
              <tr class="border-t border-primary/[0.06]">
                <td class="p-3 font-medium text-primary">AHAlife</td>
                <td class="p-3">CTO</td>
                <td class="p-3">Startup era, ecommerce, BNPL, small-business lending themes.</td>
              </tr>
              <tr class="border-t border-primary/[0.06]">
                <td class="p-3 font-medium text-primary">33Across</td>
                <td class="p-3">Senior engineering</td>
                <td class="p-3">AdTech, big data.</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="text-text-muted text-xs italic mb-6">Source: americanexpress.io/u/sachindevand, LinkedIn /in/sdevand <span class="inline-block bg-emerald-100 text-emerald-800 text-[10px] font-bold tracking-wider uppercase px-1.5 py-0.5 rounded ml-1">Confirmed</span></p>

        <h3 class="font-semibold text-primary text-lg mb-3">Public Voice &amp; Themes</h3>
        <div class="bg-white rounded-xl p-5 shadow-sm mb-6">
          <ul class="space-y-2 text-sm text-text-muted">
            <li><span class="font-medium text-primary">Active poster on LinkedIn</span>: consistent hashtags: <span class="font-medium">#teamamex #amextech #ai</span> <span class="inline-block bg-emerald-100 text-emerald-800 text-[10px] font-bold tracking-wider uppercase px-1.5 py-0.5 rounded ml-1">Confirmed</span>. He celebrates team wins publicly, which signals a leader who values visible recognition.</li>
            <li><span class="font-medium text-primary">"Consumer digital experiences powered by advanced technologies"</span> is the phrase he uses about his work <span class="inline-block bg-emerald-100 text-emerald-800 text-[10px] font-bold tracking-wider uppercase px-1.5 py-0.5 rounded ml-1">Confirmed</span>: useful language to mirror back.</li>
            <li><span class="font-medium text-primary">AI/ML emphasis</span>: his bio explicitly calls out AI &amp; ML capabilities. He has been a consistent commentator on how Amex applies AI to the card experience <span class="inline-block bg-emerald-100 text-emerald-800 text-[10px] font-bold tracking-wider uppercase px-1.5 py-0.5 rounded ml-1">Confirmed</span>.</li>
            <li><span class="font-medium text-primary">Education and background</span>: BS in Computer Science from IIT Bombay <span class="inline-block bg-emerald-100 text-emerald-800 text-[10px] font-bold tracking-wider uppercase px-1.5 py-0.5 rounded ml-1">Confirmed</span>. Lives in Jersey City <span class="inline-block bg-emerald-100 text-emerald-800 text-[10px] font-bold tracking-wider uppercase px-1.5 py-0.5 rounded ml-1">Confirmed</span>: so commute and after-hours availability cuts both ways.</li>
            <li><span class="font-medium text-primary">Likely operating style</span>: engineering-led executive with consumer-product instincts. He cares about shipping and about how the work looks externally <span class="inline-block bg-amber-100 text-amber-800 text-[10px] font-bold tracking-wider uppercase px-1.5 py-0.5 rounded ml-1">Likely</span>.</li>
          </ul>
        </div>

        <div class="bg-secondary/5 border border-secondary/15 rounded-xl p-5">
          <p class="text-sm text-primary"><span class="font-semibold">How to use this in the interview:</span> <span class="text-text-muted">Reference the Marcus chapter when it's relevant ("I noticed Sachin built consumer experiences at Marcus before Amex, I imagine some of the same playbook applies here."). Use his exact phrase, "consumer digital experiences powered by advanced technologies", once. Don't quote a specific LinkedIn post unless you've actually read it.</span></p>
        </div>
      </div>
    </section>

    <!-- 2. Sachin Web & Social Presence -->
    <section id="sachin-presence" class="py-12 md:py-16 bg-warm">
      <div class="max-w-3xl mx-auto px-6">
        <p class="text-secondary text-xs font-semibold tracking-[0.15em] uppercase mb-2">Section 2</p>
        <h2 class="font-serif text-2xl md:text-3xl text-primary mb-6">Sachin's Web &amp; Social Presence</h2>
        <p class="text-text-muted text-sm mb-6">Pre-load every link below on your phone before Friday. Knowing where his public footprint lives, and what he chooses to put there, tells you who he is as a leader.</p>

        <h3 class="font-semibold text-primary text-lg mb-3">Primary profiles</h3>
        <div class="bg-white rounded-xl p-5 shadow-sm mb-6">
          <ul class="space-y-3 text-sm text-text-muted">
            <li>
              <span class="font-medium text-primary">LinkedIn:</span>
              <a href="https://www.linkedin.com/in/sdevand" target="_blank" rel="noopener" class="text-secondary underline hover:no-underline">linkedin.com/in/sdevand</a>
              <span class="inline-block bg-emerald-100 text-emerald-800 text-[10px] font-bold tracking-wider uppercase px-1.5 py-0.5 rounded ml-1">Confirmed</span>
              <span class="block text-text-muted/80 text-xs mt-0.5">Where he actually posts. Active under #teamamex #amextech #ai. His role-expansion announcement (Dec 2023) drew 69 comments; his Amex-hire post drew 108. He responds in threads.</span>
            </li>
            <li>
              <span class="font-medium text-primary">X / Twitter:</span>
              <a href="https://twitter.com/sdevand" target="_blank" rel="noopener" class="text-secondary underline hover:no-underline">twitter.com/sdevand</a>
              <span class="inline-block bg-emerald-100 text-emerald-800 text-[10px] font-bold tracking-wider uppercase px-1.5 py-0.5 rounded ml-1">Confirmed</span>
              <span class="block text-text-muted/80 text-xs mt-0.5">Quieter than LinkedIn but worth a glance for the topics he amplifies.</span>
            </li>
            <li>
              <span class="font-medium text-primary">Amex Technology author page:</span>
              <a href="https://americanexpress.io/u/sachindevand/" target="_blank" rel="noopener" class="text-secondary underline hover:no-underline">americanexpress.io/u/sachindevand</a>
              <span class="inline-block bg-emerald-100 text-emerald-800 text-[10px] font-bold tracking-wider uppercase px-1.5 py-0.5 rounded ml-1">Confirmed</span>
              <span class="block text-text-muted/80 text-xs mt-0.5">His official Amex Tech profile. This is where the Platinum-refresh post sits, the most quotable artifact you have.</span>
            </li>
            <li>
              <span class="font-medium text-primary">Qwoted (media-source profile):</span>
              <a href="https://app.qwoted.com/sources/sachin-devand" target="_blank" rel="noopener" class="text-secondary underline hover:no-underline">app.qwoted.com/sources/sachin-devand</a>
              <span class="inline-block bg-emerald-100 text-emerald-800 text-[10px] font-bold tracking-wider uppercase px-1.5 py-0.5 rounded ml-1">Confirmed</span>
              <span class="block text-text-muted/80 text-xs mt-0.5">He has a journalist-facing source page, signals he is open to press and treats public voice as part of the job. Read his bio there for the exact language he uses about himself.</span>
            </li>
          </ul>
        </div>

        <h3 class="font-semibold text-primary text-lg mb-3">Secondary references &amp; coverage</h3>
        <div class="bg-white rounded-xl p-5 shadow-sm mb-6">
          <ul class="space-y-3 text-sm text-text-muted">
            <li>
              <span class="font-medium text-primary">The Markets Cafe hire announcement:</span>
              <a href="https://themarketscafe.com/american-express-just-hired-a-new-top-cloud-executive-who-was-the-cto-at-groupon-and-led-tech-at-goldman-sachs-marcus/" target="_blank" rel="noopener" class="text-secondary underline hover:no-underline">"Amex just hired a new top cloud executive…"</a>
              <span class="inline-block bg-emerald-100 text-emerald-800 text-[10px] font-bold tracking-wider uppercase px-1.5 py-0.5 rounded ml-1">Confirmed</span>
              <span class="block text-text-muted/80 text-xs mt-0.5">Confirms how Amex framed his hire publicly: "top cloud executive." That's the mandate he came in with.</span>
            </li>
            <li>
              <span class="font-medium text-primary">CTO Rank leader profile:</span>
              <a href="https://ctorank.com/leaders/sachin-devand/" target="_blank" rel="noopener" class="text-secondary underline hover:no-underline">ctorank.com/leaders/sachin-devand</a>
              <span class="inline-block bg-amber-100 text-amber-800 text-[10px] font-bold tracking-wider uppercase px-1.5 py-0.5 rounded ml-1">Likely</span>
            </li>
            <li>
              <span class="font-medium text-primary">Weekday (working-at-Amex view):</span>
              <a href="https://www.weekday.works/people/sachin-devand-sdevand" target="_blank" rel="noopener" class="text-secondary underline hover:no-underline">weekday.works/people/sachin-devand-sdevand</a>
              <span class="inline-block bg-amber-100 text-amber-800 text-[10px] font-bold tracking-wider uppercase px-1.5 py-0.5 rounded ml-1">Likely</span>
            </li>
            <li>
              <span class="font-medium text-primary">Crunchbase person profile:</span>
              <a href="https://www.crunchbase.com/person/sachin-devand" target="_blank" rel="noopener" class="text-secondary underline hover:no-underline">crunchbase.com/person/sachin-devand</a>
              <span class="inline-block bg-amber-100 text-amber-800 text-[10px] font-bold tracking-wider uppercase px-1.5 py-0.5 rounded ml-1">Likely</span>
            </li>
          </ul>
        </div>

        <h3 class="font-semibold text-primary text-lg mb-3">Quick facts (verified across multiple sources)</h3>
