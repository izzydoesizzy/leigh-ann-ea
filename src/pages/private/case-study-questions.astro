              <span class="text-secondary font-bold text-sm mt-0.5 flex-shrink-0">7.</span>
              <div>
                <p class="text-white/90 text-sm font-medium leading-relaxed">You moved from Trinidad to the US at 21. You built a corporate career from zero in a new country while simultaneously building a culinary career that got you in the New York Times. When you think about what drives you, what's the real answer? Not "I'm passionate about operations." The real one.</p>
                <p class="text-white/25 text-xs mt-2 italic">Why this matters: The best personal brands are built on something true. This is the foundation.</p>
              </div>
            </div>
          </div>

          <div class="bg-white/[0.06] border border-white/[0.08] rounded-xl p-5">
            <div class="flex gap-3">
              <span class="text-secondary font-bold text-sm mt-0.5 flex-shrink-0">8.</span>
              <div>
                <p class="text-white/90 text-sm font-medium leading-relaxed">What's the one thing about your work that has never made it onto a resume or a LinkedIn profile? The thing you do that's hard to put into words but that everyone who's worked with you would recognize immediately?</p>
                <p class="text-white/25 text-xs mt-2 italic">Why this matters: The intangible is often the differentiator. We need to find the words for it.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="py-12 md:py-16 bg-cream">
      <div class="max-w-2xl mx-auto px-6 text-center">
        <h2 class="font-serif text-2xl text-primary mb-3">Ready to record?</h2>
        <p class="text-text-muted text-sm leading-relaxed mb-6">
          Open Otter or your voice recorder and go role by role. Talk through the answers naturally. Send the recordings to Izzy before Session 2 so we can build your case studies with real detail.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href={`${base}private/`} class="inline-block bg-primary text-white text-sm px-6 py-3 rounded-full hover:bg-primary/90 transition-colors">
            Back to Dashboard
          </a>
          <a href="https://otter.ai" target="_blank" rel="noopener" class="inline-block bg-secondary text-white text-sm px-6 py-3 rounded-full hover:bg-secondary/90 transition-colors">
            Open Otter.ai
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
  </div>
</Layout>

<style>
  .calc-slider {
    -webkit-appearance: none;
    appearance: none;
    height: 6px;
    border-radius: 9999px;
    background: linear-gradient(to right, #C4873B var(--fill, 50%), rgba(27, 42, 74, 0.1) var(--fill, 50%));
    outline: none;
    cursor: pointer;
  }
  .calc-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: #C4873B;
    border: 3px solid white;
    box-shadow: 0 1px 6px rgba(0, 0, 0, 0.15);
    cursor: pointer;
  }
  .calc-slider::-moz-range-thumb {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: #C4873B;
    border: 3px solid white;
    box-shadow: 0 1px 6px rgba(0, 0, 0, 0.15);
    cursor: pointer;
  }
  .calc-tab {
    border-color: rgba(27, 42, 74, 0.1);
    color: #6B6B6B;
    background: white;
  }
  .calc-tab:hover {
    border-color: rgba(27, 42, 74, 0.2);
    color: #1A1A1A;
  }
  .calc-tab.active {
    background: rgba(196, 135, 59, 0.1);
    border-color: #C4873B;
    color: #1B2A4A;
    font-weight: 500;
  }
</style>

<script>
  const fmt = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
  const numFmt = new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 });

  // ── Slider fill helper ──────────────────────────────────────
  function updateFill(slider: HTMLInputElement) {
    const min = parseFloat(slider.min);
    const max = parseFloat(slider.max);
    const val = parseFloat(slider.value);
    const pct = ((val - min) / (max - min)) * 100;
    slider.style.setProperty('--fill', pct + '%');
  }

  // ── Tab switching ───────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.calc-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.calc-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      document.querySelectorAll('.calc-panel').forEach(p => p.classList.add('hidden'));
      const target = document.getElementById('calc-' + tab.dataset.calc);
      if (target) target.classList.remove('hidden');
    });
  });

  // ── Helper: get slider value ────────────────────────────────
  function sv(id: string): number {
    const el = document.getElementById(id) as HTMLInputElement;
    return parseFloat(el.value);
  }
  function setT(id: string, text: string) {
    const el = document.getElementById(id);
    if (el) el.textContent = text;
  }
  function setH(id: string, html: string) {
    const el = document.getElementById(id);
    if (el) el.innerHTML = html;
  }

  // ── CALC 1: Executive Time Value ────────────────────────────
  function calcExecTime() {
    const comp = sv('et-comp');
    const hours = sv('et-hours');
    const execs = sv('et-execs');

    setT('et-comp-val', fmt.format(comp));
    setT('et-hours-val', hours + ' hrs');
    setT('et-execs-val', String(execs));

    const hourlyRate = comp / 2080;
    const annualHours = hours * 52 * execs;
    const annualValue = annualHours * hourlyRate;
    const weeks = annualHours / 40;

    setT('et-result-hours', numFmt.format(annualHours) + ' hours');
    setT('et-result-weeks', weeks.toFixed(1) + ' weeks');
    setT('et-result-value', fmt.format(annualValue));
    setH('et-result-statement', `"Recovered approximately ${fmt.format(annualValue)} in annual executive capacity by managing calendar, communications, and operational workflows for ${execs} C-suite leader${execs > 1 ? 's' : ''}."`);

    document.querySelectorAll('#calc-exec-time .calc-slider').forEach(s => updateFill(s as HTMLInputElement));
  }

  // ── CALC 2: Process Efficiency ──────────────────────────────
  function calcProcess() {
    const before = sv('pe-before');
    const after = sv('pe-after');
    const people = sv('pe-people');
    const freq = sv('pe-freq');
    const rate = sv('pe-rate');

    setT('pe-before-val', before + ' min');
    setT('pe-after-val', after + ' min');
    setT('pe-people-val', String(people));
    setT('pe-freq-val', freq + 'x');
    setT('pe-rate-val', '$' + rate + '/hr');

    const savedPerUse = before - after;
    const totalMinYear = savedPerUse * people * freq * 12;
    const totalHours = totalMinYear / 60;
    const totalWeeks = totalHours / 40;
    const dollarValue = totalHours * rate;
    const pctImprove = before > 0 ? Math.round(((before - after) / before) * 100) : 0;

    setT('pe-result-peruse', Math.max(0, savedPerUse) + ' minutes');
    setT('pe-result-hours', numFmt.format(Math.max(0, totalHours)) + ' hours');
    setT('pe-result-weeks', totalWeeks.toFixed(1) + ' full work weeks');
    setT('pe-result-value', fmt.format(Math.max(0, dollarValue)));
    setT('pe-result-pct', Math.max(0, pctImprove) + '%');
    setH('pe-result-statement', `"Redesigned [process] reducing completion time by ${Math.max(0, pctImprove)}%, saving approximately ${numFmt.format(Math.max(0, totalHours))} hours annually across a team of ${people}."`);

    document.querySelectorAll('#calc-process .calc-slider').forEach(s => updateFill(s as HTMLInputElement));
  }

  // ── CALC 3: Stakeholder Scale ───────────────────────────────
  function calcStakeholder() {
    const count = sv('sh-count');
    const touch = sv('sh-touch');
    const mins = sv('sh-mins');
    const markets = sv('sh-markets');

    setT('sh-count-val', numFmt.format(count));
    setT('sh-touch-val', String(touch));
    setT('sh-mins-val', mins + ' min');
    setT('sh-markets-val', String(markets));

    const annualTouchpoints = count * touch * 12;
    const annualHours = (annualTouchpoints * mins) / 60;
    const fte = annualHours / 2080;

    setT('sh-result-touchpoints', numFmt.format(annualTouchpoints));
    setT('sh-result-hours', numFmt.format(Math.round(annualHours)) + ' hours');
    setT('sh-result-markets', markets + ' market' + (markets > 1 ? 's' : ''));
    setT('sh-result-fte', fte.toFixed(1) + ' FTEs');
    setH('sh-result-statement', `"Coordinated ${numFmt.format(annualTouchpoints)}+ annual touchpoints across ${numFmt.format(count)} stakeholders in ${markets} market${markets > 1 ? 's' : ''}, managing approximately ${numFmt.format(Math.round(annualHours))} hours of cross-functional communication."`);

    document.querySelectorAll('#calc-stakeholder .calc-slider').forEach(s => updateFill(s as HTMLInputElement));
  }

  // ── CALC 4: Error Prevention ────────────────────────────────
  function calcError() {
    const volume = sv('er-volume');
    const beforeRate = sv('er-before');
    const afterRate = sv('er-after');
    const txns = sv('er-txns');

    setT('er-volume-val', fmt.format(volume));
    setT('er-before-val', beforeRate.toFixed(1) + '%');
    setT('er-after-val', afterRate.toFixed(1) + '%');
    setT('er-txns-val', numFmt.format(txns));

    const rateImprove = Math.max(0, beforeRate - afterRate);
    const errorsPreventedMonth = Math.round(txns * (rateImprove / 100));
    const annualRiskProtected = volume * 12 * (rateImprove / 100);

    setT('er-result-errors', errorsPreventedMonth + ' fewer errors');
    setT('er-result-value', fmt.format(annualRiskProtected));
    setT('er-result-improve', rateImprove.toFixed(1) + ' percentage points');
    const accBefore = (100 - beforeRate).toFixed(0);
    const accAfter = (100 - afterRate).toFixed(0);
    setH('er-result-statement', `"Improved payment accuracy from ${accBefore}% to ${accAfter}%, protecting approximately ${fmt.format(annualRiskProtected)} annually across ${fmt.format(volume)}+ in monthly transaction volume."`);

    document.querySelectorAll('#calc-error .calc-slider').forEach(s => updateFill(s as HTMLInputElement));
  }

  // ── CALC 5: Team Ramp-Up ────────────────────────────────────
  function calcRampup() {
    const people = sv('ru-people');
    const salary = sv('ru-salary');
    const oldMonths = sv('ru-old');
    const newMonths = sv('ru-new');

    setT('ru-people-val', String(people));
    setT('ru-salary-val', fmt.format(salary));
    setT('ru-old-val', oldMonths + ' months');
    setT('ru-new-val', newMonths + ' months');

    const monthsSaved = Math.max(0, oldMonths - newMonths);
    const totalMonthsSaved = monthsSaved * people;
    const pctReduction = oldMonths > 0 ? Math.round((monthsSaved / oldMonths) * 100) : 0;
    const valuePerHire = (salary / 12) * monthsSaved * 0.5;
    const totalValue = valuePerHire * people;

    setT('ru-result-pct', pctReduction + '% faster');
    setT('ru-result-months', totalMonthsSaved + ' month' + (totalMonthsSaved !== 1 ? 's' : ''));
    setT('ru-result-value', fmt.format(totalValue));
    setH('ru-result-statement', `"Designed onboarding program for ${people} admin professional${people > 1 ? 's' : ''}, reducing ramp-up time by ${pctReduction}% and recovering approximately ${fmt.format(totalValue)} in team productivity."`);

    document.querySelectorAll('#calc-rampup .calc-slider').forEach(s => updateFill(s as HTMLInputElement));
  }

  // ── CALC 6: Event & Budget ──────────────────────────────────
  function calcEvent() {
    const budget = sv('ev-budget');
    const reduction = sv('ev-reduction');
    const events = sv('ev-events');
    const years = sv('ev-years');

    setT('ev-budget-val', fmt.format(budget));
    setT('ev-reduction-val', reduction + '%');
    setT('ev-events-val', String(events));
    setT('ev-years-val', String(years));

    const annualSavings = budget * (reduction / 100);
    const totalSavings = annualSavings * years;
    const perEvent = events > 0 ? annualSavings / events : 0;

    setT('ev-result-annual', fmt.format(annualSavings));
    setT('ev-result-total', fmt.format(totalSavings));
    setT('ev-result-per', fmt.format(perEvent));
    setH('ev-result-statement', `"Reduced annual event costs by ${reduction}% through vendor renegotiation and logistics optimization, saving ${fmt.format(annualSavings)} per year across ${events} events."`);

    document.querySelectorAll('#calc-event .calc-slider').forEach(s => updateFill(s as HTMLInputElement));
  }

  // ── CALC 7: Board Prep Value ────────────────────────────────
  function calcBoard() {
    const members = sv('bd-members');
    const rate = sv('bd-rate');
    const meetings = sv('bd-meetings');
    const duration = sv('bd-duration');
    const saved = sv('bd-saved');

    setT('bd-members-val', String(members));
    setT('bd-rate-val', '$' + numFmt.format(rate) + '/hr');
    setT('bd-meetings-val', String(meetings));
    setT('bd-duration-val', duration + ' hrs');
    setT('bd-saved-val', saved + ' hrs');

    const meetingHours = members * meetings * duration;
    const meetingValue = meetingHours * rate;
    const savedHours = members * meetings * saved;
    const savedValue = savedHours * rate;

    setT('bd-result-meeting-hours', numFmt.format(meetingHours) + ' hours');
    setT('bd-result-meeting-value', fmt.format(meetingValue));
    setT('bd-result-saved-hours', numFmt.format(savedHours) + ' hours/year');
    setT('bd-result-saved-value', fmt.format(savedValue));
    setH('bd-result-statement', `"Streamlined board meeting preparation for ${members}-member board, reducing individual prep time by ${saved} hours per meeting and recovering ${fmt.format(savedValue)} annually in aggregate board member time."`);

    document.querySelectorAll('#calc-board .calc-slider').forEach(s => updateFill(s as HTMLInputElement));
  }

  // ── Wire up all sliders ─────────────────────────────────────
  function wireCalc(prefix: string, fn: () => void) {
    document.querySelectorAll(`#calc-${prefix} .calc-slider`).forEach(s => {
      s.addEventListener('input', fn);
    });
  }

  wireCalc('exec-time', calcExecTime);
  wireCalc('process', calcProcess);
  wireCalc('stakeholder', calcStakeholder);
  wireCalc('error', calcError);
  wireCalc('rampup', calcRampup);
  wireCalc('event', calcEvent);
  wireCalc('board', calcBoard);

  // ── Initial calculations ────────────────────────────────────
  calcExecTime();
  calcProcess();
  calcStakeholder();
  calcError();
  calcRampup();
  calcEvent();
  calcBoard();

  // ── Reveal animations ───────────────────────────────────────
  const revealEls = document.querySelectorAll("[data-reveal], [data-reveal-stagger]");
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("revealed");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: "0px 0px -60px 0px" }
  );
  revealEls.forEach((el) => observer.observe(el));
</script>
