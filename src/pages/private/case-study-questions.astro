---
import Layout from "../../layouts/Layout.astro";
import PrivateHeader from "../../components/PrivateHeader.astro";
import Footer from "../../components/Footer.astro";

const base = import.meta.env.BASE_URL;

// Tag color map for consistent styling
const tagColors: Record<string, string> = {
  "Metrics": "bg-blue-100 text-blue-700",
  "Before/After": "bg-amber-100 text-amber-700",
  "Testimonial": "bg-purple-100 text-purple-700",
  "Process": "bg-emerald-100 text-emerald-700",
  "People": "bg-pink-100 text-pink-700",
  "Failure": "bg-red-100 text-red-700",
  "Scale": "bg-cyan-100 text-cyan-700",
  "Budget": "bg-green-100 text-green-700",
  "Transition": "bg-orange-100 text-orange-700",
  "Culture": "bg-violet-100 text-violet-700",
  "Origin": "bg-rose-100 text-rose-700",
  "Brand": "bg-indigo-100 text-indigo-700",
  "Growth": "bg-teal-100 text-teal-700",
  "Confidential": "bg-slate-200 text-slate-700",
  "Industry": "bg-sky-100 text-sky-700",
};

const roles = [
  {
    id: "ascend",
    company: "Ascend Wellness Holdings",
    title: "Senior EA to CEO & President",
    dates: "Jan 2025 - Jan 2026",
    industry: "Cannabis MSO (Multi-State Operator)",
    leaders: "Sam Brill (CEO), Frank Parullo (President)",
    context: `We started digging into this on our first call and got deep into the quarterly earnings overhaul. You described building a 5-6 week pre-earnings timeline from scratch, coordinating across IR, commercial (David Gacom), cultivation teams, and finance (Roman, Laura Warren). You introduced hard and soft deadlines because cannabis leadership "were not accustomed to being held accountable in that way." You managed 200+ stakeholders across 7 markets and handled board/committee/IR operations.`,
    questions: [
      {
        label: "Walk me through one complete earnings call using your new system.",
        tags: ["Process", "Before/After"],
        drilldowns: ["What happened in week 1 of prep?", "What happened in week 5?", "Who owned what in your system?", "What did the actual call day look like vs. before?"],
        calc: { type: "time-value", id: "asc-earnings", label: "Earnings prep time saved", inputs: [
          { id: "asc-e-hours", label: "Hours of exec prep saved per quarter", min: 2, max: 40, step: 1, value: 10, unit: "hrs" },
          { id: "asc-e-rate", label: "CEO hourly rate equivalent", min: 100, max: 1000, step: 25, value: 350, unit: "$" },
        ], formula: "hours * rate * 4", resultLabel: "Annual exec time recovered" },
      },
      {
        label: "Did Sam or Frank use the public speaking consultant you screened?",
        tags: ["People", "Before/After"],
        drilldowns: ["What was their presentation style like before?", "What specifically changed after?", "Did analysts or investors comment on the improvement?"],
      },
      {
        label: "Which states were you covering across the 7 markets?",
        tags: ["Scale"],
        drilldowns: ["How many people in each market did you coordinate with?", "What communication tools/systems did you use?", "Did a system exist before you, or did you build it from scratch?"],
        calc: { type: "scale", id: "asc-markets", label: "Stakeholder communication load", inputs: [
          { id: "asc-m-people", label: "Stakeholders across all markets", min: 10, max: 500, step: 10, value: 200, unit: "" },
          { id: "asc-m-touch", label: "Avg. touchpoints per person/month", min: 1, max: 10, step: 1, value: 2, unit: "x" },
          { id: "asc-m-mins", label: "Minutes per touchpoint", min: 2, max: 30, step: 1, value: 8, unit: "min" },
        ], formula: "people * touch * mins * 12 / 60", resultLabel: "Communication hours managed/year" },
      },
      {
        label: "Give me one specific M&A deal you were involved in.",
        tags: ["Confidential", "Industry"],
        drilldowns: ["What was your exact role in the transaction?", "Were you managing due diligence docs, coordinating legal, or scheduling?", "What would have fallen apart without you?"],
      },
      {
        label: "How many board meetings per year did you prep for?",
        tags: ["Process", "Metrics"],
        drilldowns: ["How far in advance did you start prep?", "What did the board materials look like before you improved them?", "How many board members?", "Did you also handle committee meetings?"],
        calc: { type: "board", id: "asc-board", label: "Board prep value", inputs: [
          { id: "asc-b-meetings", label: "Meetings per year", min: 2, max: 12, step: 1, value: 4, unit: "" },
          { id: "asc-b-members", label: "Board members", min: 3, max: 15, step: 1, value: 7, unit: "" },
          { id: "asc-b-saved", label: "Prep hours saved per member per meeting", min: 0.5, max: 8, step: 0.5, value: 2, unit: "hrs" },
          { id: "asc-b-rate", label: "Board member hourly rate", min: 100, max: 2000, step: 50, value: 500, unit: "$" },
        ], formula: "meetings * members * saved * rate", resultLabel: "Annual board member time recovered" },
      },
      {
        label: "What broke when you left Ascend?",
        tags: ["Transition", "Testimonial"],
        drilldowns: ["How long did the transition take?", "Did they hire a replacement?", "What's the first thing that fell apart?", "Did anyone reach out afterward asking how you did something?"],
      },
      {
        label: "What would Laura Warren say about you in one sentence?",
        tags: ["Testimonial", "People"],
        drilldowns: ["What about Courtney (now at Matteo)?", "What's the one thing they'd say you did that nobody else could?"],
      },
      {
        label: "Where does the 98% stakeholder satisfaction rate come from?",
        tags: ["Metrics"],
        drilldowns: ["Was there a formal survey or internal review?", "If it's your estimate, what's the evidence?", "Did anyone ever complain about your work? What happened?"],
      },
      {
        label: "Tell me one thing at Ascend that didn't go as planned.",
        tags: ["Failure"],
        drilldowns: ["What caused it?", "How did you find out?", "What did you do to fix it?", "What did you learn?"],
      },
    ]
  },
  {
    id: "immunovant",
    company: "Immunovant",
    title: "Senior EA to CEO & General Counsel",
    dates: "Sep 2019 - Jul 2024",
    industry: "Clinical-Stage Biopharmaceutical",
    leaders: "CEO (name TBD), General Counsel, Pam Connelly (first CFO & CHRO), Renee (CFO), Pete Norini",
    context: `Longest tenure and biggest growth story: nearly 5 years at a clinical-stage biopharma. You went from supporting the CEO to also supporting the General Counsel. You founded and led the Culture Committee. You designed onboarding for 6 admin professionals with a 20% ramp-up reduction. Resume claims 30% decision-making improvement and 22% satisfaction increase. Almost no specific stories yet.`,
    questions: [
      {
        label: "How many people were at Immunovant when you joined vs. when you left?",
        tags: ["Growth", "Metrics"],
        drilldowns: ["How many offices?", "What clinical stage were they in at each point?", "When did your role expand from 1 exec to 2?"],
      },
      {
        label: "Give me one time the CEO and General Counsel needed you at the same moment.",
        tags: ["People"],
        drilldowns: ["What was each person's need?", "How did you decide who got priority?", "Did either of them notice the conflict?"],
      },
      {
        label: "Whose idea was the Culture Committee?",
        tags: ["Culture", "Metrics"],
        drilldowns: ["How did you pitch it to leadership?", "What specific programs did you run?", "How many people participated?", "What changed that you can point to?"],
      },
      {
        label: "How many months did it take a new admin to get fully productive before your onboarding system?",
        tags: ["Process", "Metrics"],
        drilldowns: ["And how many months after?", "What specific materials or systems did you create?", "How many admins went through your program?"],
        calc: { type: "ramp", id: "imm-onboard", label: "Onboarding savings", inputs: [
          { id: "imm-o-people", label: "People onboarded", min: 1, max: 20, step: 1, value: 6, unit: "" },
          { id: "imm-o-salary", label: "Avg. annual salary", min: 40000, max: 150000, step: 5000, value: 75000, unit: "$" },
          { id: "imm-o-before", label: "Old ramp-up (months)", min: 1, max: 12, step: 1, value: 5, unit: "mo" },
          { id: "imm-o-after", label: "New ramp-up (months)", min: 1, max: 12, step: 1, value: 4, unit: "mo" },
        ], formula: "people * (salary / 12) * (before - after) * 0.5", resultLabel: "Productivity recovered" },
      },
      {
        label: "What was happening before you that made decisions slow?",
        tags: ["Before/After"],
        drilldowns: ["What specifically did you change?", "Can you give me one decision that moved faster because of you?", "How do you know it was 30% faster?"],
      },
      {
        label: "Was there an employee satisfaction survey?",
        tags: ["Metrics", "Culture"],
        drilldowns: ["What year(s) was it run?", "What was the score before vs. after?", "What did you specifically do that contributed to the increase?"],
      },
      {
        label: "What would Pam Connelly say about you if I called her right now?",
        tags: ["Testimonial"],
        drilldowns: ["Not the polished version. Her actual words.", "What's the one thing she relied on you for that she couldn't get from anyone else?"],
      },
      {
        label: "What's the biggest fire you put out that nobody knew about?",
        tags: ["Failure", "Confidential"],
        drilldowns: ["What would have happened if you hadn't caught it?", "Did anyone ever find out?", "How much time/money did it save?"],
      },
      {
        label: "Were you involved in any FDA-related coordination?",
        tags: ["Industry"],
        drilldowns: ["Clinical trial milestones?", "Investor updates around data readouts?", "What was your specific role in those moments?"],
      },
      {
        label: "What was the reaction when you gave your notice?",
        tags: ["Transition"],
        drilldowns: ["What was the honest trigger for leaving?", "Did they try to keep you?", "How long did it take to replace you?"],
      },
    ]
  },
  {
    id: "third-bridge",
    company: "Third Bridge",
    title: "Senior EA to President, Global Lead & MD Operations",
    dates: "Oct 2017 - Sep 2019",
    industry: "Expert Network / Financial Services Research",
    leaders: "President (name TBD)",
    context: `Global role spanning NYC and London. You reduced event costs by 15%, expanded admin teams in both cities, and created onboarding manuals. First role with international scope. Very little detail beyond resume bullets.`,
    questions: [
      {
        label: "Were you coordinating directly with hedge fund and PE firm clients?",
        tags: ["Industry"],
        drilldowns: ["Or was your scope purely internal?", "How did the expert-network business model affect your day-to-day?"],
      },
      {
        label: "What time did your day start to cover the London office?",
        tags: ["Scale", "Process"],
        drilldowns: ["What did a typical split-timezone day look like?", "How many people were you coordinating with in London?"],
      },
      {
        label: "What was the total annual event budget you managed?",
        tags: ["Budget", "Metrics"],
        drilldowns: ["How many events per year?", "What specifically did you change to cut costs by 15%?", "Was quality maintained or improved?"],
        calc: { type: "savings", id: "tb-events", label: "Event savings", inputs: [
          { id: "tb-e-budget", label: "Annual event budget", min: 50000, max: 1000000, step: 10000, value: 200000, unit: "$" },
          { id: "tb-e-pct", label: "Cost reduction %", min: 1, max: 30, step: 1, value: 15, unit: "%" },
        ], formula: "budget * pct / 100", resultLabel: "Annual savings" },
      },
      {
        label: "How many people did you hire for the admin teams?",
        tags: ["People", "Growth"],
        drilldowns: ["NYC vs. London?", "Did you write the job descriptions?", "Run the interviews?", "What was the team size before vs. after?"],
      },
      {
        label: "How many onboarding manuals did you create?",
        tags: ["Process"],
        drilldowns: ["What processes did they cover?", "Are they still in use?", "How much faster did new admins get up to speed?"],
      },
      {
        label: "What's the biggest thing the jump from PwC to Third Bridge taught you?",
        tags: ["Transition"],
        drilldowns: ["What was harder at a smaller global company?", "What was easier?"],
      },
      {
        label: "If the President described your impact in one sentence, what would it be?",
        tags: ["Testimonial"],
        drilldowns: ["What's the one thing they'd miss most?"],
      },
    ]
  },
  {
    id: "pwc",
    company: "PwC",
    title: "Senior Team Assistant, NY Metro State & Local Tax",
    dates: "Nov 2012 - Jun 2017",
    industry: "Big Four Professional Services",
    leaders: "Tax partners (names TBD)",
    context: `Nearly 5 years at PwC. 98% on-time delivery, Fortune 500 workflows, Marketing & Sales budget tracking, mentor and onboarding buddy. Strong brand name but almost no stories.`,
    questions: [
      {
        label: "How many partners and senior managers did you support simultaneously?",
        tags: ["Scale", "Metrics"],
        drilldowns: ["Were you the only assistant for all of them?", "Or part of an admin team? If so, how many admins total?"],
      },
      {
        label: "Give me one specific Fortune 500 workflow you managed end to end.",
        tags: ["Process"],
        drilldowns: ["Engagement letters? Client billing? Audit support?", "What made it complex?", "How often did you run this workflow?"],
      },
      {
        label: "How large was the Marketing & Sales budget you tracked?",
        tags: ["Budget"],
        drilldowns: ["What system did you use?", "What was the state of the budget tracking before you?", "Did you find and fix any errors?"],
        calc: { type: "savings", id: "pwc-budget", label: "Budget oversight value", inputs: [
          { id: "pwc-b-budget", label: "Annual budget managed", min: 50000, max: 2000000, step: 25000, value: 500000, unit: "$" },
          { id: "pwc-b-error", label: "Error rate you prevented (%)", min: 0.5, max: 10, step: 0.5, value: 2, unit: "%" },
        ], formula: "budget * error / 100", resultLabel: "Errors prevented annually" },
      },
      {
        label: "How many people did you onboard as a mentor?",
        tags: ["People", "Culture"],
        drilldowns: ["Did you create any materials, or was it informal?", "Was this a formal PwC program or did you volunteer?"],
      },
      {
        label: "What did you handle during tax season that nobody else could?",
        tags: ["Industry"],
        drilldowns: ["How did workload change Jan-Apr vs. the rest of the year?", "How many extra hours per week during peak?"],
      },
      {
        label: "What finally made you leave PwC for Third Bridge?",
        tags: ["Transition"],
        drilldowns: ["What kept you for nearly 5 years?", "What was the pull vs. the push?"],
      },
      {
        label: "Name one person from PwC who would vouch for you today.",
        tags: ["Testimonial"],
        drilldowns: ["Partner, senior manager, or fellow assistant?", "What would they specifically say?"],
      },
    ]
  },
  {
    id: "reich-tang",
    company: "Reich & Tang",
    title: "Operations EA to VP & COO",
    dates: "Feb 2010 - Sep 2012",
    industry: "Financial Services / Asset Management",
    leaders: "VP & COO (name TBD)",
    context: `Supported the VP & COO. Created procedure manuals, improved accuracy by 20%, reduced training time by 30%, distributed reports to 100+ brokers. Overlaps with DGB Management.`,
    questions: [
      {
        label: "Were you doing operations-level work or traditional EA work?",
        tags: ["Process", "Scale"],
        drilldowns: ["What was the COO responsible for?", "Where exactly did you fit in that structure?"],
      },
      {
        label: "How many procedure manuals did you write?",
        tags: ["Process", "Before/After"],
        drilldowns: ["What processes did they cover?", "Were people relying on tribal knowledge before?", "Are any of them still in use?"],
      },
      {
        label: "How often did you distribute reports to the 100+ brokers?",
        tags: ["Scale", "Metrics"],
        drilldowns: ["Daily? Weekly?", "What was in the reports?", "What was the consequence if a report was late or wrong?"],
      },
      {
        label: "What was inaccurate before you improved accuracy by 20%?",
        tags: ["Metrics", "Before/After"],
        drilldowns: ["What specifically did you change?", "How did you measure the improvement?", "And for the 30% training time reduction, what was taking so long before?"],
      },
      {
        label: "How did you balance Reich & Tang and DGB Management at the same time?",
        tags: ["Transition"],
        drilldowns: ["Was DGB a side business?", "How many hours per week on each?"],
      },
    ]
  },
  {
    id: "dgb",
    company: "DGB Management",
    title: "Virtual Operations Consultant",
    dates: "Aug 2009 - Dec 2011",
    industry: "Independent Consulting",
    leaders: "Your own business",
    context: `First independent consulting work. 30% reduction in routine process time for clients. We know almost nothing about this.`,
    questions: [
      {
        label: "What does DGB stand for?",
        tags: ["Origin", "Brand"],
        drilldowns: ["Was it a registered LLC?", "How did you get your first client?"],
      },
      {
        label: "How many clients did you have at any given time?",
        tags: ["Scale"],
        drilldowns: ["What industries?", "What size companies?", "What were they paying you?"],
      },
      {
        label: "Tell me about one specific project that went well.",
        tags: ["Process"],
        drilldowns: ["What was the client's problem?", "What did you build or fix?", "What was the outcome?"],
      },
      {
        label: "Which client saw the 30% process time reduction?",
        tags: ["Metrics"],
        drilldowns: ["Which process?", "How did you measure it?", "What did you change?"],
      },
      {
        label: "Why did you stop and go back to full-time at PwC?",
        tags: ["Transition"],
        drilldowns: ["Was it income stability?", "Burnout?", "An opportunity you couldn't pass up?"],
      },
    ]
  },
  {
    id: "bearingpoint",
    company: "BearingPoint",
    title: "Financial Operations Administrator",
    dates: "Dec 2007 - Jul 2009",
    industry: "Management & Technology Consulting",
    leaders: "Manager/Director (name TBD)",
    context: `First major US corporate role. Processed $10M+ in monthly payments at 99% accuracy. Reduced billing discrepancies by 20%. BearingPoint went bankrupt in 2009.`,
    questions: [
      {
        label: "How many invoices or transactions did you process per month?",
        tags: ["Metrics", "Process"],
        drilldowns: ["What systems were you using?", "What happened if you made an error on a payment?", "Who caught mistakes if they happened?"],
        calc: { type: "accuracy", id: "bp-payments", label: "Payment accuracy value", inputs: [
          { id: "bp-p-volume", label: "Monthly payment volume ($)", min: 1000000, max: 20000000, step: 500000, value: 10000000, unit: "$" },
          { id: "bp-p-before", label: "Error rate before (%)", min: 1, max: 10, step: 0.5, value: 5, unit: "%" },
          { id: "bp-p-after", label: "Error rate after (%)", min: 0, max: 10, step: 0.5, value: 1, unit: "%" },
        ], formula: "volume * 12 * (before - after) / 100", resultLabel: "Annual risk dollars protected" },
      },
      {
        label: "What was it like working through BearingPoint's bankruptcy?",
        tags: ["Failure", "Growth"],
        drilldowns: ["What extra responsibilities landed on you?", "How did the team respond?", "What did that experience teach you?"],
      },
      {
        label: "What was causing the billing discrepancies you fixed?",
        tags: ["Before/After", "Process"],
        drilldowns: ["Was it a process problem, a data problem, or a people problem?", "What did you actually change?"],
      },
      {
        label: "What was the biggest adjustment moving from Trinidad to a US corporate office?",
        tags: ["Origin"],
        drilldowns: ["What surprised you most?", "What skills from Petrotrin transferred directly?"],
      },
    ]
  },
  {
    id: "petrotrin",
    company: "Petrotrin (Petroleum Company of Trinidad and Tobago)",
    title: "Administrative Assistant, Office of the VP of Oil & Refining",
    dates: "Pre-2006",
    industry: "State-Owned Oil & Gas",
    leaders: "VP of Oil & Refining (name TBD)",
    context: `Your origin story. Petrotrin was Trinidad's state-owned oil company. You worked in the office of the VP of Oil & Refining. We know almost nothing.`,
    questions: [
      {
        label: "How old were you when you started at Petrotrin?",
        tags: ["Origin"],
        drilldowns: ["How did you get the job?", "Was this your first real office job?"],
      },
      {
        label: "How big was the VP of Oil & Refining's team?",
        tags: ["Scale"],
        drilldowns: ["What was the VP responsible for?", "What was your scope within that office?"],
      },
      {
        label: "What did you learn at Petrotrin that you still use today?",
        tags: ["Origin", "Brand"],
        drilldowns: ["A habit? A way of thinking? A specific skill?"],
      },
      {
        label: "Was there a specific moment you decided to leave Trinidad?",
        tags: ["Transition"],
        drilldowns: ["Or was it gradual?", "What were you hoping to find in the US?"],
      },
      {
        label: "What did you do between arriving in the US (2006) and starting at BearingPoint (late 2007)?",
        tags: ["Transition"],
        drilldowns: ["That's roughly 18 months. Working? Studying? Getting settled?"],
      },
    ]
  },
];
---

<Layout noindex={true} title="Case Study Deep-Dive Questions | Leigh-Ann Martin" description="Role-by-role questions to extract metrics, impact, and stories for case studies.">
  <PrivateHeader />
  <div class="md:ml-60">
  <main>
    <!-- Hero -->
    <section class="bg-primary pt-24 pb-12 md:pt-16 md:pb-16">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-secondary mb-4">Session 2 Prep</p>
        <h1 class="font-serif text-3xl md:text-4xl text-white leading-tight mb-4">
          Case Study Deep-Dive Questions
        </h1>
        <p class="text-white/50 text-base leading-relaxed max-w-xl mx-auto mb-6">
          Role-by-role questions designed to uncover the real metrics, stories, and impact behind your career. The goal is to build case studies with specifics that make hiring managers and prospects say "I need that person."
        </p>
        <div class="flex flex-wrap justify-center gap-2">
          <span class="bg-white/10 border border-white/10 text-white/60 text-xs px-3 py-1 rounded-full">8 Roles</span>
          <span class="bg-white/10 border border-white/10 text-white/60 text-xs px-3 py-1 rounded-full">65+ Questions</span>
          <span class="bg-white/10 border border-white/10 text-white/60 text-xs px-3 py-1 rounded-full">Metrics &amp; Impact</span>
          <span class="bg-white/10 border border-white/10 text-white/60 text-xs px-3 py-1 rounded-full">Testimonial Language</span>
        </div>
      </div>
    </section>

    <!-- Quick Nav -->
    <section class="bg-primary/95 border-t border-white/[0.06] py-4 sticky top-14 md:top-0 z-40">
      <div class="max-w-4xl mx-auto px-6">
        <div class="flex flex-wrap justify-center gap-2 text-xs">
          <a href="#how-to-use" class="text-white/40 hover:text-white/70 transition-colors">How to Use</a>
          <span class="text-white/15">|</span>
          <a href="#quantification" class="text-white/40 hover:text-white/70 transition-colors">Quantification</a>
          <span class="text-white/15">|</span>
          <a href="#calculators" class="text-white/40 hover:text-white/70 transition-colors">Calculators</a>
          <span class="text-white/15">|</span>
          {roles.map((role, i) => (
            <>
              <a href={`#${role.id}`} class="text-white/40 hover:text-white/70 transition-colors">{role.company.split(' ')[0]}{role.company === "Petrotrin (Petroleum Company of Trinidad and Tobago)" ? "" : ""}</a>
              {i < roles.length - 1 && <span class="text-white/15">|</span>}
            </>
          ))}
          <span class="text-white/15">|</span>
          <a href="#cross-cutting" class="text-white/40 hover:text-white/70 transition-colors">Cross-Cutting</a>
        </div>
      </div>
    </section>

    <!-- How to Use -->
    <section id="how-to-use" class="py-12 md:py-16 bg-cream">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="font-serif text-2xl text-primary mb-6">How to Use This</h2>
        <div class="bg-white rounded-2xl shadow-sm border border-primary/[0.06] p-6 space-y-4">
          <div class="flex gap-3">
            <span class="text-secondary font-bold text-sm mt-0.5">1.</span>
            <div><span class="font-semibold text-primary text-sm">Go role by role.</span> <span class="text-text-muted text-sm">Start with the most recent (Ascend) and work backwards. The newer roles need the most depth. The older ones need the stories you haven't told yet.</span></div>
          </div>
          <div class="flex gap-3">
            <span class="text-secondary font-bold text-sm mt-0.5">2.</span>
            <div><span class="font-semibold text-primary text-sm">Use Otter or voice notes.</span> <span class="text-text-muted text-sm">Don't type these out. Open Otter (or your phone's voice recorder) and talk through the answers out loud. Talking pulls out details that writing filters out.</span></div>
          </div>
          <div class="flex gap-3">
            <span class="text-secondary font-bold text-sm mt-0.5">3.</span>
            <div><span class="font-semibold text-primary text-sm">Be specific, not polished.</span> <span class="text-text-muted text-sm">We're not looking for perfect answers. We want real numbers, real names, real situations. "I think it was about 15 invoices a day" is more useful than "I managed high-volume payment processing."</span></div>
          </div>
          <div class="flex gap-3">
            <span class="text-secondary font-bold text-sm mt-0.5">4.</span>
