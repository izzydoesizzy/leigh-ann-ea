---
import Layout from "../../layouts/Layout.astro";
import PrivateHeader from "../../components/PrivateHeader.astro";
import Footer from "../../components/Footer.astro";

const base = import.meta.env.BASE_URL;

// Transcript summaries from 12 otter.ai recordings captured 2026-04-15.
// Narrative context per role + signal strength (how much quantifiable material is in each transcript).
// Drill-down questions per achievement live on /private/case-study-questions (richer, with inline calculators).
// No em dashes anywhere on this page.

// Source order is chronological (oldest first) for readability; displayed in reverse-chronological order.
const transcriptsChronological = [
  {
    id: "petrotrin",
    company: "Petrotrin",
    roleSubtitle: "Admin Assistant, Office of VP of Oil & Refining (Trinidad)",
    tenure: "Age 18 through September 2006, pre-US migration",
    file: "Petrotrin_otter_ai.txt",
    narrative:
      "Leigh-Ann's first real job. Admin under the EA of the VP of Oil & Refining at Trinidad's state-owned oil company (largest employer in the country before its 2018 dissolution). Got the role through family legacy: \"Everyone in my family worked at Petron in some capacity or the other.\" Scope was filing, interoffice mail, and observing how other EAs coordinated with VPs and chiefs. She named listening as the transferable skill she still uses. Migration to the US came suddenly when her biological mother filed her green card and the US government gave her a 3-month window to land.",
    signal: "Low. Narrative only, no metrics.",
  },
  {
    id: "bearingpoint",
    company: "BearingPoint",
    roleSubtitle: "Administrative support, Finance / Treasury (NYC)",
    tenure: "November 2007 through Chapter 11 wind-down",
    file: "BearingPoint_otter_ai.txt",
    narrative:
      "First US corporate role. Survived the firm's Chapter 11 bankruptcy, watching the team move from the American Express towers on Vesey Street to a co-working space off Broadway as the operation consolidated to India for cost reasons. Supported four named finance leaders: VP, Treasurer, VP of Finance, plus one more. First exposure to AP/AR, wire transfers, and cross-border ops (India and British Virgin Islands teams). Asked directly about invoice volumes and specific fixes, she answered \"I cannot remember at all\" three times.",
    signal: "Low. Context for career narrative; no recallable metrics.",
  },
  {
    id: "dgb",
    company: "DGB Management",
    roleSubtitle: "Virtual assistant, internal operations",
    tenure: "Overlapped BearingPoint wind-down through R&T",
    file: "DGB_otter_ai.txt",
    narrative:
      "Sourced this role herself during BearingPoint's Chapter 11 period by pitching a BearingPoint EA colleague: \"I will be available to be a virtual assistant soon.\" Built DGB's first centralized client database in Microsoft Access, replacing a field-then-home data-entry workflow. Portfolio was 2 to 3 active clients at any given time, with a pipeline growing via new proposals. Contributed to two landed projects: Downtown Brooklyn (Fulton Street Mall) and Beacon, NY. Left when hours dwindled and PwC came through.",
    signal: "Medium. One confirmed process-time claim, two named project wins.",
  },
  {
    id: "rt",
    company: "Rich & Tang (R&T)",
    roleSubtitle: "Ops / customer-service team support",
    tenure: "Pre-PwC return; ended in mass layoffs",
    file: "R&T_otter_ai.txt",
    narrative:
      "Team-facing support for the COO and VP of Customer Service and their broader team (NY HQ plus NJ satellite for systems). Authored one procedural management manual covering lockbox management, ops and customer service support, and backup reception. Distributed broker reports ad hoc and quarterly. Introduced multi-stage review (not end-stage-only QC) which improved correspondence accuracy approximately 20%. Ended at mass layoffs; she had already applied to PwC for the second time.",
    signal: "Medium. 20% accuracy gain (needs baseline), 1 manual authored.",
  },
  {
    id: "pwc",
    company: "PwC",
    roleSubtitle: "Team Assistant, Indirect Tax and State/Income Franchise Tax, plus Thought Leadership",
    tenure: "~2.5 to 3 years in Tax before adding Thought Leadership scope",
    file: "PwC_otter_ai.txt",
    narrative:
      "Supported two tax teams simultaneously inside State and Local Tax (Indirect Tax and State/Income Franchise Tax) across the full ladder from associate to MD. Managed Time and Expense for every director and MD in both groups. After 2.5 to 3 years she added the Thought Leadership Managing Director (internal firm services), taking ownership of the weekly budget-tracking workflow and the WHIP (Work-In-Progress) report: a comprehensive purchase-order view spanning 3 POs by 500 companies. Mentored and onboarded four incoming team assistants as a volunteer (not a formal program) and co-created department-specific onboarding materials. Endured a 9-month heavy tax season annually (Jan to April extension filings plus June to Sept hard deadlines on Sept 15, Oct 15, Nov 15). Named \"invaluable\" by the team for proactive pickup. Left reluctantly: \"I loved working at PwC.\"",
    signal: "High. Multiple confirmed quantified scopes.",
  },
  {
    id: "thirdbridge",
    company: "Third Bridge",
    roleSubtitle: "Internal firm services EA, NY and London",
    tenure: "Post-PwC through pre-Immunovant",
    file: "ThirdBridge_otter_ai.txt",
    narrative:
      "Expert network consultancy, internal firm services (no client-facing work). Started workday at 8am ET to overlap with the London afternoon. Supported the MD of Operations (NY), later added the Chief HR Officer (NY), and covered the President/Founder when he visited from London. Hired one NY admin (HR plus sales dual-hat), co-wrote the JD with HR, and sat on interviews. Also interviewed for a London admin. Authored one EA-function onboarding manual covering office-manager backup, travel/expense policy, external-guest protocols, and the President/CEO NY-visit playbook. Enforced ELT meeting budget discipline via policy plus historical-data benchmarking. Operated through the Texas office opening, which drove additional HR hiring.",
    signal: "Medium. Multi-geo coverage, 1 hire, 1 manual; ELT budget specifics missing.",
  },
  {
    id: "imvt",
    company: "Immunovant",
    roleSubtitle: "Sole Executive Assistant scaled to EA Team Lead, pre-IPO biopharma",
    tenure: "September 2019 onward",
    file: "IMVT1 + IMVT2 (2 recordings)",
    narrative:
      "Joined September 2019 as employee #17, 18, or 19. Started supporting the CEO and General Counsel; by March 2020 (pre-pandemic) she was supporting five C-suite execs as the only EA: CEO, General Counsel, Chief Medical Officer, CFO, and Chief Technology & Development Officer. Two offices: NY (leadership) and North Carolina (clinical trials). CEO, CFO, and CTDO all lived in different states; heavy regional travel. Built the EA function from zero: \"before I came in, they didn't really have anyone to take on the administrative tasks of the team.\" Designed the EA onboarding system (centralized tabs-in-spreadsheets instead of Word docs, buddy pairings, suggested intro-meeting agendas per internal stakeholder, weekly all-EA syncs, cross-EA 1:1s). Pre-system new-admin ramp: 6 to 8 weeks. Decision velocity for ELT/SLT improved approximately 30% per CEO review feedback. Co-founded the Culture Committee with HR during the pandemic remote pivot: 6 to 10 members on a 6-month rotation, charter tied to company KPIs and scorecard, post-event survey program, small budget from the VP of Financial Planning. Owned FDA coordination for the regulatory team (internal meetings, FDA meetings, electronic filing, fireproof lockbox for hardcopy correspondence, clinical-trial ad boards). Ran pre-IPO investor relations with the IR manager (press releases, earnings, no-deal road shows). Managed a high-friction General Counsel (\"Mark\") by taking on a bi-weekly ELT meeting's coordination other leaders wouldn't touch. Departure: let go in a leadership restructuring, not a PIP. CFO reference quote (Pam Connealy): \"lovely to work with, responsive, knew what I was doing. Not being reactionary, took action.\"",
    signal: "High. Richest transcript set for behavioral-interview stories and confirmed scopes.",
  },
  {
    id: "ascend",
    company: "Ascend Wellness Holdings",
    roleSubtitle: "Executive Assistant, Investor Relations",
    tenure: "End of January 2025 through January 2026",
    file: "Ascend1-4 (4 recordings)",
    narrative:
      "CSE and OTCQX-listed public cannabis operator across 7 states (NJ, PA, IL, MA, MD, MI, OH per dossier; she named five and flagged the last two as markets she couldn't recall). First earnings cycle (Q4 2024, reported April 2025) exposed prep-process gaps; in July 2025 after Q1 she rebuilt the system and ran it for Q2. New cadence: 6 to 8 weeks out, 1:1s with Mattio Communications (external IR), Legal, and VP Financial Planning; Week-5 official kickoff with all stakeholders; SharePoint folder rollover, template scrubbing, and access provisioning in Week 1; external vendor realignment by moving the Mattio director mid-cycle. Run-of-show for earnings day: IT/AV setup, CEO/President/CFO travel and prep windows, chairman pre-meetings, Mattio pre-meetings, CEO script practice ~1.5 weeks pre-call. Q2 process improvements: granted the Chief Commercial Officer script access so his paragraphs could be signed off without back-and-forth, pulled the VP of Marketing into live prep meetings instead of asking after-the-fact. Screened a public-speaking consultant for CEO Sam (he met more than once, declined on price). Established Ascend's first quarterly board-meeting cadence (\"they didn't even have board meetings on the calendar\" at hire); in September 2025, planned the full 2026 board and committee calendar 12 months ahead. Governance scope: 8-person board convening (4 external directors plus 4 Ascend executives: CEO, CFO, President, Chief Counsel). Owned two standing committees: Audit and Compensation. Joined the weekly M&A meeting at CEO Sam's request for \"more executive presence,\" captured follow-ups, built a follow-up dashboard with leads and timelines, created presentation mock-ups for the Director of M&A. Chairman of the board gave her his personal phone number and exchanged direct text messages; the 98% stakeholder-satisfaction stat used in her consulting proposal traces here (her own estimate, not a formal survey). Departure rationale: \"I strive better when there's structure.\"",
    signal: "High. Most defensible board, governance, and earnings-system narrative.",
  },
];

const transcripts = transcriptsChronological.toReversed();

const signalStyles: Record<string, string> = {
  "High": "bg-emerald-100 text-emerald-700",
  "Medium": "bg-amber-100 text-amber-700",
  "Low": "bg-slate-200 text-slate-600",
};

function signalBadge(signal: string): { label: string; classes: string } {
  const first = signal.split(".")[0].trim();
  const classes = signalStyles[first] || "bg-slate-200 text-slate-600";
  return { label: first, classes };
}

const topTen = [
  "Built the Immunovant EA function from zero; supported 5 C-suite execs as sole EA between Sept 2019 and March 2020 (CEO, GC, CMO, CFO, CTDO).",
  "Established quarterly board meetings at Ascend (none were on the calendar when she arrived) and planned the full 2026 board and committee calendar in September 2025, 12 months ahead.",
  "Co-founded the Immunovant Culture Committee (6 to 10 members, 6-month rotation) with charter aligned to company KPIs and post-event satisfaction surveys.",
  "Rebuilt Ascend's earnings-call prep into a repeatable 6 to 8 week system after one cycle in-role; ran it for Q2 2025.",
  "Supported two PwC tax teams simultaneously (Indirect Tax and State/Income Franchise Tax) across the full ladder from associate to MD, plus Thought Leadership MD for internal firm services.",
  "Owned PwC's Thought Leadership WHIP workflow at 3 purchase orders by 500 companies scale, with weekly maintenance and pivot-table analysis.",
  "Coordinated Ascend's 8-person board (4 external directors plus 4 executives) and 2 standing committees (Audit and Compensation).",
  "Built the Immunovant EA onboarding system (spreadsheet tabs, buddy pairings, weekly all-EA syncs) from a 6 to 8 week pre-system ramp baseline.",
  "Coordinated FDA meeting prep for a pre-IPO biopharma: CEO, CMO, and General Counsel readiness, fireproof lockbox for hardcopy FDA correspondence, ad-board coordination.",
  "Authored an EA-function onboarding manual at Third Bridge covering office-manager backup, travel/expense policy, external-guest protocols, and the President/CEO NY-visit playbook.",
];
---

<Layout noindex={true} title="Brag Sheet | Leigh-Ann Martin" description="12 intake-transcript summaries plus the top-10 career achievements to lead with.">
  <PrivateHeader />
  <div class="md:ml-60">
  <main>
    <!-- Hero -->
    <section class="bg-primary pt-24 pb-12 md:pt-16 md:pb-16">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-secondary mb-4">Brag Sheet</p>
        <h1 class="font-serif text-3xl md:text-4xl text-white leading-tight mb-4">
          12 transcripts, 20 years, one brag sheet.
        </h1>
        <p class="text-white/50 text-base leading-relaxed max-w-xl mx-auto">
          A per-transcript narrative summary of every otter.ai recording you made, plus the top 10 confirmed achievements to lead with in interviews. For drill-down questions per achievement with inline calculators, see <a href={`${base}private/case-study-questions`} class="text-secondary hover:text-secondary/80 transition-colors underline underline-offset-2">Case Study Questions</a>.
        </p>
      </div>
    </section>

    <!-- Jump nav -->
    <section class="py-5 bg-cream border-b border-primary/[0.06]">
      <div class="max-w-4xl mx-auto px-6">
        <div class="flex flex-wrap gap-2 justify-start items-center">
          <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-text-muted mr-3">Jump to</p>
          <a href="#transcripts" class="inline-block bg-white border border-primary/10 text-primary px-3 py-1.5 rounded-full text-xs font-medium hover:bg-primary hover:text-white transition-all">Transcripts</a>
          <a href="#top-10" class="inline-block bg-white border border-primary/10 text-primary px-3 py-1.5 rounded-full text-xs font-medium hover:bg-primary hover:text-white transition-all">Top 10</a>
        </div>
      </div>
    </section>

    <!-- Transcript summaries -->
    <section id="transcripts" class="py-12 md:py-16 bg-cream">
      <div class="max-w-4xl mx-auto px-6">
        <div class="mb-8">
          <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-secondary mb-3">Part 1</p>
          <h2 class="font-serif text-2xl md:text-3xl text-primary leading-tight mb-3">Transcript summaries, role by role.</h2>
          <p class="text-text-muted leading-relaxed max-w-2xl">
            One card per otter.ai transcript. Each card shows the role, tenure, narrative summary, and signal strength (how much quantifiable material is in each recording).
          </p>
        </div>

        <div class="space-y-4">
          {transcripts.map((t) => {
            const sig = signalBadge(t.signal);
            return (
              <article id={t.id} class="bg-white rounded-2xl shadow-sm border border-primary/[0.06] p-6 md:p-7">
                <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-1 mb-2">
                  <h3 class="font-serif text-xl md:text-2xl text-primary leading-snug">{t.company}</h3>
                  <p class="text-[11px] font-mono text-text-muted/60 tracking-tight">{t.file}</p>
                </div>
                <p class="text-secondary text-sm font-medium mb-1">{t.roleSubtitle}</p>
                <p class="text-text-muted text-xs mb-4 uppercase tracking-wide">{t.tenure}</p>
                <p class="text-text leading-relaxed mb-5 text-[15px]">{t.narrative}</p>
                <div class="flex items-center gap-3">
                  <span class={`text-[10px] font-semibold tracking-[0.15em] uppercase px-2.5 py-1 rounded-full ${sig.classes}`}>
                    {sig.label} signal
                  </span>
                  <p class="text-text-muted/70 text-xs">{t.signal}</p>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Top 10 leaderboard -->
    <section id="top-10" class="py-16 md:py-20 bg-primary text-white">
      <div class="max-w-3xl mx-auto px-6">
        <div class="mb-8">
          <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-secondary mb-3">Part 2</p>
          <h2 class="font-serif text-2xl md:text-3xl leading-tight mb-3">The ten achievements to lead with.</h2>
          <p class="text-white/60 leading-relaxed">
            Confirmed only. Ranked by defensibility and signal-to-noise. These are the ones that walk into a final-round interview, a negotiation, or a pitch deck without flinching.
          </p>
        </div>

        <ol class="space-y-4 list-decimal list-outside ml-6 marker:text-secondary marker:font-serif marker:text-lg">
          {topTen.map((item) => (
            <li class="pl-2">
              <p class="text-white/90 leading-relaxed text-[15px]">{item}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- Back to dashboard -->
    <section class="py-10 bg-cream">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <a href={`${base}private`} class="text-text-muted/50 text-xs hover:text-text-muted transition-colors">
          &larr; Back to dashboard
        </a>
      </div>
    </section>
  </main>
  <Footer />
  </div>
</Layout>
