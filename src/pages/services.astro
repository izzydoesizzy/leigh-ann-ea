    <!-- Who This Is For -->
    <section class="py-16 md:py-24 bg-cream">
      <div class="max-w-3xl mx-auto px-6">
        <div class="text-center mb-10" data-reveal>
          <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-secondary mb-4">Ideal Clients</p>
          <h2 class="font-serif text-3xl md:text-4xl text-primary leading-tight">
            Who this is for
          </h2>
        </div>

        <div class="bg-white rounded-2xl shadow-sm p-8" data-reveal>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-secondary mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <div>
                <p class="font-semibold text-primary text-sm">C-suite at growth-stage companies</p>
