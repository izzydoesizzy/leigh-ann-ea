    <!-- Decision Guidance -->
    <section class="py-12 md:py-16 bg-warm">
      <div class="max-w-3xl mx-auto px-6">
        <div class="bg-white rounded-2xl shadow-sm border border-primary/[0.06] p-8" data-reveal>
          <h3 class="font-serif text-xl text-primary text-center mb-6">Not sure which tier?</h3>
          <div class="space-y-3">
            <div class="flex items-start gap-3">
              <span class="text-secondary font-serif text-lg font-bold mt-0.5">1</span>
              <p class="text-text-muted text-sm leading-relaxed"><span class="text-primary font-medium">Your calendar and inbox are a fire drill?</span> Start with Tier 1.</p>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-secondary font-serif text-lg font-bold mt-0.5">2</span>
              <p class="text-text-muted text-sm leading-relaxed"><span class="text-primary font-medium">You have a board or investors?</span> You need Tier 2.</p>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-secondary font-serif text-lg font-bold mt-0.5">3</span>
              <p class="text-text-muted text-sm leading-relaxed"><span class="text-primary font-medium">You need someone who can run a leadership meeting when you're traveling?</span> That's Tier 3.</p>
            </div>
            <div class="flex items-start gap-3 pt-2 border-t border-primary/[0.06]">
              <span class="text-secondary font-serif text-lg font-bold mt-0.5">?</span>
