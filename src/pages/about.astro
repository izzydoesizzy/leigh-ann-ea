---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Timeline from "../components/Timeline.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";

const base = import.meta.env.BASE_URL;
---

<Layout title="About | Leigh-Ann Martin — Fractional Executive Assistant & Chief of Staff">
  <Header />
  <main>
    <!-- Hero -->
    <section class="bg-primary pt-28 pb-16 md:pt-36 md:pb-20">
      <div class="max-w-5xl mx-auto px-6 grid md:grid-cols-12 gap-10 items-center">
        <div class="md:col-span-4 flex justify-center">
          <div class="w-48 h-48 md:w-64 md:h-64 rounded-2xl overflow-hidden ring-1 ring-white/10 shadow-2xl">
            <img
              src={`${base}leigh-ann.jpg`}
              alt="Leigh-Ann Martin"
              class="w-full h-full object-cover"
            />
          </div>
        </div>
        <div class="md:col-span-8">
          <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-secondary mb-4">About</p>
          <h1 class="font-serif text-3xl md:text-4xl text-white leading-tight mb-6">
            12 years of executive operations. From Big Four audit seasons to pre-IPO board rooms.
          </h1>
          <p class="text-white/55 text-base md:text-lg leading-relaxed max-w-xl">
            I started in oil and gas in Trinidad, worked my way through Big Four accounting at PwC, supported the CEO of a pre-IPO biotech, and ran investor relations for a multi-state cannabis operator across 7 markets. Now I bring all of that to founders and executives who need someone who has already done this at every scale.
          </p>
        </div>
      </div>
    </section>

    <!-- Dual Expertise -->
    <section class="py-16 md:py-24 bg-cream">
      <div class="max-w-4xl mx-auto px-6">
        <div class="grid md:grid-cols-2 gap-10" data-reveal>
          <div>
            <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-secondary mb-4">The Executive Side</p>
            <h2 class="font-serif text-2xl md:text-3xl text-primary leading-tight mb-4">
              Strategic operations, not task execution
            </h2>
            <p class="text-text-muted text-[15px] leading-relaxed mb-4">
              I've supported CEOs, CFOs, and General Counsels across industries where precision matters: biotech companies navigating FDA compliance, publicly traded cannabis operators managing investor relations across seven markets, Big Four accounting during audit season.
            </p>
            <p class="text-text-muted text-[15px] leading-relaxed">
              The work goes beyond scheduling. Board meeting orchestration. Investor correspondence. Executive onboarding. Cross-functional project management. Building the systems that let leaders focus on leading.
            </p>
          </div>
          <div>
            <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-secondary mb-4">The Chef Side</p>
            <h2 class="font-serif text-2xl md:text-3xl text-primary leading-tight mb-4">
              Precision, timing, and hospitality
            </h2>
            <p class="text-text-muted text-[15px] leading-relaxed mb-4">
              I'm also a classically trained chef, graduating with highest honors from the Institute of Culinary Education. My pop-up dinner series "A Table For Four" has been featured in The New York Times, The Washington Post, and Eater.
            </p>
            <p class="text-text-muted text-[15px] leading-relaxed">
              The same person whose 4-person pop-up dinners were featured in The New York Times also ran board prep for a biotech CEO. That's not a contradiction. It's the same skill set: precision under pressure, anticipating needs before they're spoken, and making complex orchestration look effortless.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Career Timeline -->
    <Timeline />

    <!-- Certifications -->
    <section class="py-16 md:py-24 bg-cream">
      <div class="max-w-4xl mx-auto px-6">
        <div class="grid md:grid-cols-2 gap-10">
          <div data-reveal>
            <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-secondary mb-4">Certifications</p>
            <h2 class="font-serif text-2xl text-primary leading-tight mb-6">Credentials</h2>
            <div class="grid grid-cols-2 gap-3">
              <div class="bg-white rounded-xl p-4 shadow-sm border border-primary/[0.06] text-center">
                <p class="font-semibold text-primary text-sm">CAP</p>
                <p class="text-text-muted text-xs mt-1">Certified Administrative Professional</p>
              </div>
              <div class="bg-white rounded-xl p-4 shadow-sm border border-primary/[0.06] text-center">
                <p class="font-semibold text-primary text-sm">Salesforce Admin</p>
                <p class="text-text-muted text-xs mt-1">Certified Administrator</p>
              </div>
              <div class="bg-white rounded-xl p-4 shadow-sm border border-primary/[0.06] text-center">
                <p class="font-semibold text-primary text-sm">Microsoft Office</p>
                <p class="text-text-muted text-xs mt-1">Specialist Certification</p>
              </div>
              <div class="bg-white rounded-xl p-4 shadow-sm border border-primary/[0.06] text-center">
                <p class="font-semibold text-primary text-sm">ICE Graduate</p>
                <p class="text-text-muted text-xs mt-1">Highest Honors, Culinary Arts</p>
              </div>
            </div>
          </div>

          <div data-reveal>
            <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-secondary mb-4">Tools</p>
            <h2 class="font-serif text-2xl text-primary leading-tight mb-6">Tech I work with</h2>
            <div class="flex flex-wrap gap-2">
              <span class="bg-white border border-primary/[0.06] text-text text-sm px-4 py-2 rounded-lg shadow-sm">Microsoft 365</span>
              <span class="bg-white border border-primary/[0.06] text-text text-sm px-4 py-2 rounded-lg shadow-sm">Google Workspace</span>
              <span class="bg-white border border-primary/[0.06] text-text text-sm px-4 py-2 rounded-lg shadow-sm">Salesforce</span>
              <span class="bg-white border border-primary/[0.06] text-text text-sm px-4 py-2 rounded-lg shadow-sm">Slack</span>
              <span class="bg-white border border-primary/[0.06] text-text text-sm px-4 py-2 rounded-lg shadow-sm">Zoom</span>
              <span class="bg-white border border-primary/[0.06] text-text text-sm px-4 py-2 rounded-lg shadow-sm">Notion</span>
              <span class="bg-white border border-primary/[0.06] text-text text-sm px-4 py-2 rounded-lg shadow-sm">Concur</span>
              <span class="bg-white border border-primary/[0.06] text-text text-sm px-4 py-2 rounded-lg shadow-sm">Expensify</span>
              <span class="bg-white border border-primary/[0.06] text-text text-sm px-4 py-2 rounded-lg shadow-sm">Canva</span>
              <span class="bg-white border border-primary/[0.06] text-text text-sm px-4 py-2 rounded-lg shadow-sm">Claude AI</span>
              <span class="bg-white border border-primary/[0.06] text-text text-sm px-4 py-2 rounded-lg shadow-sm">Asana</span>
              <span class="bg-white border border-primary/[0.06] text-text text-sm px-4 py-2 rounded-lg shadow-sm">Monday.com</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Chef Connection -->
    <section class="py-16 md:py-24 bg-primary">
      <div class="max-w-3xl mx-auto px-6 text-center" data-reveal>
        <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-secondary mb-4">The Other Side</p>
        <h2 class="font-serif text-3xl md:text-4xl text-white leading-tight mb-6">
          When I'm not running executive operations
        </h2>
        <p class="text-white/60 text-base leading-relaxed mb-8 max-w-xl mx-auto">
          I cook. My pop-up dinner series "A Table For Four" brings Trinidadian cuisine and classical technique together for intimate four-person meals. Featured in The New York Times, The Washington Post, and Eater. Held in New York, Wisconsin, London, and Grenada.
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a
            href="https://leighannmartin.com"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 text-white/60 px-6 py-2.5 rounded-full text-sm font-medium border border-white/15 hover:border-white/30 hover:text-white/80 transition-all"
          >
            leighannmartin.com
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </a>
          <a
            href="https://instagram.com/chefleighann"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 text-white/60 px-6 py-2.5 rounded-full text-sm font-medium border border-white/15 hover:border-white/30 hover:text-white/80 transition-all"
          >
            @chefleighann
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <CTA heading="Want to work together?" subtext="I take on a small number of clients at a time. If you think there's a fit, let's talk." />
  </main>
  <Footer />
</Layout>

<script>
  const revealEls = document.querySelectorAll("[data-reveal], [data-reveal-stagger]");
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("revealed");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: "0px 0px -60px 0px" }
  );
  revealEls.forEach((el) => observer.observe(el));
</script>
