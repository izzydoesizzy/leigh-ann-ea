<Layout title="Click-to-Send Outreach | Leigh-Ann Martin">
  <Header />
  <main>
    <!-- Hero -->
    <section class="bg-primary pt-28 pb-16 md:pt-36 md:pb-20">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-secondary mb-4">Outreach Dashboard</p>
        <h1 class="font-serif text-3xl md:text-4xl lg:text-5xl text-white leading-tight mb-6">
          Click-to-Draft Emails
        </h1>
        <p class="text-white/55 text-base md:text-lg leading-relaxed max-w-xl mx-auto">
          Every email below opens directly in Gmail with the subject, recipient, and body pre-filled. Review, personalize, and send.
        </p>
      </div>
    </section>

    <!-- Instructions -->
    <section class="py-6 bg-secondary/10 border-b border-secondary/20">
      <div class="max-w-3xl mx-auto px-6">
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-secondary mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <div class="text-sm text-primary">
            <p class="font-semibold mb-1">How to use</p>
            <p class="text-text-muted">Click any "Draft Email" button to open a pre-written email in your default mail app. <strong>Before sending:</strong> review the email, add any personal touches, and make sure the tone feels right. These are conversation starters, not pitches.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="py-8 bg-warm border-b border-primary/[0.06]">
      <div class="max-w-5xl mx-auto px-6">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-center">
          <div>
            <p class="font-serif text-3xl text-secondary">{contacts.filter(c => c.priority === 'A').length}</p>
            <p class="text-text-muted text-sm">Priority A</p>
          </div>
          <div>
            <p class="font-serif text-3xl text-primary">{contacts.filter(c => c.priority === 'B').length}</p>
            <p class="text-text-muted text-sm">Priority B</p>
          </div>
          <div>
            <p class="font-serif text-3xl text-text-muted">{contacts.length}</p>
            <p class="text-text-muted text-sm">Total Contacts</p>
          </div>
          <div>
            <p class="font-serif text-3xl text-secondary">0</p>
            <p class="text-text-muted text-sm" id="sent-count">Sent</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Priority A Contacts -->
    <section class="py-12 md:py-16 bg-cream">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="font-serif text-2xl md:text-3xl text-primary mb-2">Priority A: Send This Week</h2>
        <p class="text-text-muted text-sm mb-8">These are your highest-value targets. Warm leads, strong industry matches, or companies at the perfect inflection point.</p>

        <div class="space-y-6">
          {contacts.filter(c => c.priority === 'A').map((contact, i) => (
            <div class="bg-white rounded-2xl shadow-sm border border-primary/[0.06] overflow-hidden outreach-card" data-contact-id={`a-${i}`}>
              <!-- Header -->
              <div class="p-6 border-b border-primary/[0.04]">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                  <div>
                    <div class="flex items-center gap-2 flex-wrap mb-1">
                      <h3 class="font-serif text-lg text-primary">{contact.name}</h3>
                      <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-secondary/10 text-secondary">Priority A</span>
                    </div>
                    <p class="text-text-muted text-sm">{contact.title}, {contact.company} ({contact.industry})</p>
                    <p class="text-text-muted text-xs mt-1">{contact.context}</p>
                  </div>
                  <div class="flex items-center gap-2">
                    <a
                      href={buildMailto(contact.email, contact.subject, contact.body)}
                      class="inline-flex items-center gap-2 bg-secondary text-white px-5 py-2.5 rounded-full text-sm font-semibold hover:bg-secondary/90 transition-all shadow-sm"
                      data-mailto-btn={`a-${i}`}
                    >
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                      Draft Email
                    </a>
                  </div>
                </div>
              </div>

              <!-- Email Preview (collapsed by default) -->
              <details class="group">
                <summary class="px-6 py-3 text-sm text-text-muted hover:text-primary cursor-pointer flex items-center gap-2 transition-colors">
                  <svg class="w-4 h-4 faq-chevron transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                  Preview email
                </summary>
                <div class="px-6 pb-6">
                  <div class="bg-warm rounded-lg p-4 text-sm">
                    <p class="font-semibold text-primary mb-1">To: {contact.email}</p>
                    <p class="font-semibold text-primary mb-3">Subject: {contact.subject}</p>
                    <div class="text-text-muted whitespace-pre-line leading-relaxed">{contact.body}</div>
                  </div>
                </div>
              </details>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Priority B Contacts -->
    <section class="py-12 md:py-16 bg-warm">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="font-serif text-2xl text-primary mb-2">Priority B: Send Weeks 2-3</h2>
        <p class="text-text-muted text-sm mb-8">Good matches. Send after your A-priority outreach is complete.</p>

        <div class="space-y-4">
          {contacts.filter(c => c.priority === 'B').map((contact, i) => (
            <div class="bg-white rounded-xl shadow-sm border border-primary/[0.06] overflow-hidden outreach-card" data-contact-id={`b-${i}`}>
              <div class="p-5">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                  <div>
                    <div class="flex items-center gap-2 flex-wrap mb-1">
                      <h3 class="font-serif text-base text-primary">{contact.name}</h3>
                      <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-primary/10 text-primary">Priority B</span>
                    </div>
                    <p class="text-text-muted text-xs">{contact.title}, {contact.company} ({contact.industry})</p>
                  </div>
                  <a
                    href={buildMailto(contact.email, contact.subject, contact.body)}
                    class="inline-flex items-center gap-2 bg-primary text-white px-4 py-2 rounded-full text-sm font-semibold hover:bg-primary/90 transition-all"
                    data-mailto-btn={`b-${i}`}
                  >
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                    Draft
                  </a>
                </div>
              </div>
              <details class="group">
                <summary class="px-5 py-2 text-xs text-text-muted hover:text-primary cursor-pointer flex items-center gap-1 transition-colors border-t border-primary/[0.04]">
                  <svg class="w-3 h-3 faq-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                  Preview
                </summary>
                <div class="px-5 pb-4">
                  <div class="bg-warm rounded-lg p-3 text-xs">
                    <p class="font-semibold text-primary mb-1">Subject: {contact.subject}</p>
                    <div class="text-text-muted whitespace-pre-line leading-relaxed">{contact.body}</div>
                  </div>
                </div>
              </details>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Follow-up Templates -->
    <section class="py-12 md:py-16 bg-cream">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="font-serif text-2xl text-primary mb-2">Follow-Up Sequence</h2>
        <p class="text-text-muted text-sm mb-8">Use these after your initial emails. Copy and paste into replies.</p>

        <div class="space-y-4">
          <div class="bg-white rounded-xl p-5 shadow-sm">
            <div class="flex items-center gap-2 mb-3">
              <span class="bg-secondary/10 text-secondary text-xs font-bold px-2.5 py-1 rounded-full">Day 3</span>
              <p class="font-semibold text-primary text-sm">Soft Value Add</p>
            </div>
            <div class="text-text-muted text-sm whitespace-pre-line leading-relaxed">Hi [First Name],

Quick follow-up on my note from [day]. I know your inbox is probably a case study in why you need an EA.

I put together a short checklist of the 7 operational systems every post-Series B CEO should have in place. Happy to send it over if useful, no strings attached.

Either way, I'd welcome the chance to connect.

Best,
Leigh-Ann</div>
          </div>

          <div class="bg-white rounded-xl p-5 shadow-sm">
            <div class="flex items-center gap-2 mb-3">
              <span class="bg-primary/10 text-primary text-xs font-bold px-2.5 py-1 rounded-full">Day 7</span>
              <p class="font-semibold text-primary text-sm">Social Proof</p>
            </div>
            <div class="text-text-muted text-sm whitespace-pre-line leading-relaxed">Hi [First Name],

One more thought. I recently helped a [biotech/fintech] CEO restructure their entire executive operations cadence after a [funding round/leadership transition]. Within 60 days, they had:

- Board prep time cut from 12 hours to 3 hours per quarter
- Investor update cycle running on autopilot
- 15+ hours/week freed up from scheduling and coordination

I offer a free 30-minute operations audit where I review your current setup and identify the three highest-impact areas for delegation. No pitch, just practical advice.

If that's useful, I'm here.

Best,
Leigh-Ann</div>
          </div>

          <div class="bg-white rounded-xl p-5 shadow-sm">
            <div class="flex items-center gap-2 mb-3">
              <span class="bg-gray-100 text-text-muted text-xs font-bold px-2.5 py-1 rounded-full">Day 14</span>
              <p class="font-semibold text-primary text-sm">Close the Loop</p>
            </div>
            <div class="text-text-muted text-sm whitespace-pre-line leading-relaxed">Hi [First Name],

I've reached out a couple of times and I want to respect your time.

If fractional EA support isn't relevant right now, no worries at all. If it might be relevant in the future (next fundraise, board changes, new hires), I'm happy to stay in touch.

Just reply "later" and I'll circle back in 90 days. Or "yes" and I'll send a calendar link.

Either way, wishing [Company] continued momentum.

Best,
Leigh-Ann</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Navigation -->
    <section class="py-12 bg-primary">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href={`${base}prospects`} class="inline-flex items-center gap-2 text-white/60 px-7 py-3 rounded-full text-sm font-medium border border-white/15 hover:border-white/30 hover:text-white/80 transition-all">
            View All Prospects
          </a>
          <a href={`${base}opportunities`} class="inline-flex items-center gap-2 text-white/60 px-7 py-3 rounded-full text-sm font-medium border border-white/15 hover:border-white/30 hover:text-white/80 transition-all">
            View Job Opportunities
          </a>
          <a href={`${base}services`} class="inline-flex items-center gap-2 bg-secondary text-white px-7 py-3 rounded-full text-sm font-semibold hover:bg-secondary/90 transition-all">
            View Services
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  // Track which emails have been clicked
  const buttons = document.querySelectorAll('[data-mailto-btn]');
  let sentCount = 0;

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const card = btn.closest('.outreach-card') as HTMLElement | null;
      if (card && !card.classList.contains('sent')) {
        card.classList.add('sent');
        card.style.opacity = '0.6';
        sentCount++;
        const counter = document.querySelector('#sent-count');
        if (counter) {
          const parent = counter.parentElement;
          if (parent) {
            const numEl = parent.querySelector('.font-serif');
            if (numEl) numEl.textContent = String(sentCount);
          }
        }
      }
    });
  });
</script>
