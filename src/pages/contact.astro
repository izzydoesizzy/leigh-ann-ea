---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Contact | Leigh-Ann Martin — Fractional Executive Assistant & Chief of Staff">
  <Header />
  <main>
    <!-- Hero -->
    <section class="bg-primary pt-28 pb-16 md:pt-36 md:pb-20">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-secondary mb-4">Get in Touch</p>
        <h1 class="font-serif text-3xl md:text-4xl lg:text-5xl text-white leading-tight mb-6">
          Let's talk about what you need.
        </h1>
        <p class="text-white/55 text-base md:text-lg leading-relaxed max-w-xl mx-auto">
          Every engagement starts with a conversation. Book a 30-minute call and I'll tell you honestly whether I can help.
        </p>
      </div>
    </section>

    <!-- Calendly + Contact Info -->
    <section class="py-16 md:py-24 bg-cream">
      <div class="max-w-4xl mx-auto px-6">
        <div class="grid md:grid-cols-12 gap-10">
          <!-- Calendly Embed -->
          <div class="md:col-span-8" data-reveal>
            <div class="bg-white rounded-2xl shadow-sm border border-primary/[0.06] p-8 min-h-[500px] flex items-center justify-center">
              <!-- Replace with Calendly embed when ready -->
              <!-- <div class="calendly-inline-widget" data-url="https://calendly.com/YOUR-URL" style="min-width:100%;height:600px;"></div> -->
              <!-- <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script> -->
              <div class="text-center">
                <div class="w-16 h-16 bg-secondary/10 rounded-full flex items-center justify-center mx-auto mb-4">
                  <svg class="w-8 h-8 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                </div>
                <h3 class="font-serif text-xl text-primary mb-2">Book a Consultation</h3>
                <p class="text-text-muted text-sm mb-6 max-w-sm mx-auto">
                  30 minutes. No pitch, no pressure. Just a conversation about what's not working and what would help.
                </p>
                <a
                  href="mailto:lmartinlapc@gmail.com?subject=Consultation%20Request%20%E2%80%94%20Fractional%20EA%20Partnership"
                  class="inline-flex items-center gap-2 bg-secondary text-white px-6 py-3 rounded-full text-sm font-semibold hover:bg-secondary/90 transition-all"
                >
                  Request a Call
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
                <p class="text-text-muted/60 text-xs mt-4">I respond within 24 hours on business days.</p>
              </div>
            </div>
          </div>

          <!-- Contact Details -->
          <div class="md:col-span-4" data-reveal>
            <div class="space-y-6">
              <div>
                <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-secondary mb-3">Email</p>
                <a href="mailto:lmartinlapc@gmail.com" class="text-primary font-medium hover:text-secondary transition-colors">
                  lmartinlapc@gmail.com
                </a>
              </div>

              <div>
                <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-secondary mb-3">LinkedIn</p>
                <a href="https://linkedin.com/in/leigh-ann-martin" target="_blank" rel="noopener noreferrer" class="text-primary font-medium hover:text-secondary transition-colors flex items-center gap-1.5">
                  linkedin.com/in/leigh-ann-martin
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                </a>
              </div>

              <div>
                <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-secondary mb-3">Location</p>
                <p class="text-text-muted text-sm leading-relaxed">
                  Based in the New York tri-state area. Available for remote and hybrid engagements.
                </p>
              </div>

              <div class="pt-4 border-t border-primary/[0.06]">
                <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-secondary mb-3">Confidentiality</p>
                <p class="text-text-muted text-sm leading-relaxed">
                  Every engagement begins with a mutual NDA. I've handled board-level confidential matters for 12 years. Discretion is non-negotiable.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- What happens after you book -->
    <section class="py-12 md:py-16 bg-warm">
      <div class="max-w-3xl mx-auto px-6">
        <div class="text-center mb-8" data-reveal>
          <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-secondary mb-4">What Happens Next</p>
          <h2 class="font-serif text-2xl text-primary">After you reach out</h2>
        </div>

        <div class="grid sm:grid-cols-2 gap-4" data-reveal>
          <div class="bg-white rounded-xl p-5 shadow-sm flex items-start gap-3">
            <span class="text-secondary font-serif text-lg font-bold mt-0.5">1</span>
            <div>
              <p class="font-medium text-primary text-sm">We talk for 30 minutes</p>
              <p class="text-text-muted text-xs mt-1">About what's not working, what you need, and whether there's a fit.</p>
            </div>
          </div>
          <div class="bg-white rounded-xl p-5 shadow-sm flex items-start gap-3">
            <span class="text-secondary font-serif text-lg font-bold mt-0.5">2</span>
            <div>
              <p class="font-medium text-primary text-sm">I tell you honestly whether I can help</p>
              <p class="text-text-muted text-xs mt-1">And if I can't, I'll point you to someone who can.</p>
            </div>
          </div>
          <div class="bg-white rounded-xl p-5 shadow-sm flex items-start gap-3">
            <span class="text-secondary font-serif text-lg font-bold mt-0.5">3</span>
            <div>
              <p class="font-medium text-primary text-sm">If there's a fit, you get a custom proposal</p>
              <p class="text-text-muted text-xs mt-1">Within 48 hours. Scope, tier recommendation, timeline, and pricing.</p>
            </div>
          </div>
          <div class="bg-white rounded-xl p-5 shadow-sm flex items-start gap-3">
            <span class="text-secondary font-serif text-lg font-bold mt-0.5">4</span>
            <div>
              <p class="font-medium text-primary text-sm">No pitch. No pressure. No follow-up spam.</p>
              <p class="text-text-muted text-xs mt-1">One conversation. You decide if it makes sense.</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  const revealEls = document.querySelectorAll("[data-reveal], [data-reveal-stagger]");
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("revealed");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: "0px 0px -60px 0px" }
  );
  revealEls.forEach((el) => observer.observe(el));
</script>
