---
interface Props {
  heading?: string;
  subtext?: string;
}

const base = import.meta.env.BASE_URL;
const { heading = "Ready to get your operations running?", subtext = "Book a free 30-minute consultation. No pitch, no pressure. Just a conversation about what you need and whether I can help." } = Astro.props;
---

<section class="py-20 md:py-28 bg-primary">
  <div class="max-w-2xl mx-auto px-6 text-center" data-reveal>
    <h2 class="font-serif text-3xl md:text-4xl text-white leading-tight mb-6">
      {heading}
    </h2>
    <p class="text-white/60 text-base leading-relaxed mb-10 max-w-lg mx-auto">
      {subtext}
    </p>
    <a
      href={`${base}contact`}
      class="inline-flex items-center gap-2 bg-secondary text-white px-8 py-3.5 rounded-full text-base font-semibold hover:bg-secondary/90 transition-all shadow-lg shadow-secondary/20"
    >
      Book a Consultation
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
    </a>
  </div>
</section>
