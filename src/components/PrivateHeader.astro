---
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const privatePages = [
  { label: "Prospects", href: `${base}private/prospects` },
  { label: "Outreach", href: `${base}private/outreach` },
  { label: "Opportunities", href: `${base}private/opportunities` },
  { label: "Recommendations", href: `${base}private/recommendations` },
  { label: "Interview Prep", href: `${base}private/interview-prep` },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-primary/95 backdrop-blur-lg shadow-sm">
  <nav class="max-w-6xl mx-auto px-6 flex items-center justify-between h-14">
    <div class="flex items-center gap-3">
      <a href={base} class="font-serif text-lg text-white/60 hover:text-white/80 transition-colors">Leigh-Ann Martin</a>
      <span class="text-white/20">|</span>
      <span class="text-secondary text-xs font-semibold tracking-[0.15em] uppercase">Private</span>
    </div>

    <!-- Mobile menu button -->
    <button id="private-mobile-menu-btn" class="md:hidden text-white/60 hover:text-white transition-colors" aria-label="Toggle menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-1">
      {privatePages.map(page => (
        <a
          href={page.href}
          class={`text-xs font-medium px-3 py-1.5 rounded-full transition-colors ${
            currentPath.includes(page.href.replace(base, '').replace('private/', ''))
              ? 'bg-white/10 text-white'
              : 'text-white/50 hover:text-white/80 hover:bg-white/5'
          }`}
        >
          {page.label}
        </a>
      ))}
    </div>
  </nav>

  <!-- Mobile nav -->
  <div id="private-mobile-menu" class="hidden md:hidden border-t border-white/[0.08] bg-primary/95 backdrop-blur-lg">
    <div class="px-6 py-4 space-y-2">
      {privatePages.map(page => (
        <a
          href={page.href}
          class={`block text-sm font-medium transition-colors py-1 ${
            currentPath.includes(page.href.replace(base, '').replace('private/', ''))
              ? 'text-white'
              : 'text-white/50 hover:text-white/80'
          }`}
        >
          {page.label}
        </a>
      ))}
      <div class="pt-2 border-t border-white/[0.08]">
        <a href={base} class="block text-xs text-white/30 hover:text-white/50 transition-colors py-1">
          Back to public site
        </a>
      </div>
    </div>
  </div>
</header>

<!-- Password Gate -->
<div id="private-gate" class="fixed inset-0 z-[100] bg-primary flex items-center justify-center">
  <div class="max-w-sm w-full mx-6 text-center">
    <div class="w-12 h-12 bg-secondary/10 rounded-full flex items-center justify-center mx-auto mb-6">
      <svg class="w-6 h-6 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
    </div>
    <p class="font-serif text-xl text-white mb-2">Private Section</p>
    <p class="text-white/40 text-sm mb-6">Enter the access code to continue.</p>
    <form id="gate-form" class="space-y-3">
      <input
        id="gate-input"
        type="password"
        placeholder="Access code"
        autocomplete="off"
        class="w-full bg-white/10 border border-white/15 rounded-full px-5 py-3 text-white text-sm text-center placeholder-white/30 focus:outline-none focus:border-secondary/50 focus:ring-1 focus:ring-secondary/30 transition-all"
      />
      <button
        type="submit"
        class="w-full bg-secondary text-white px-5 py-3 rounded-full text-sm font-semibold hover:bg-secondary/90 transition-all"
      >
        Enter
      </button>
    </form>
    <p id="gate-error" class="text-red-400 text-xs mt-3 hidden">Incorrect code. Try again.</p>
  </div>
</div>

<script>
  // Mobile menu toggle
  const btn = document.getElementById('private-mobile-menu-btn');
  const menu = document.getElementById('private-mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // Password gate
  const STORAGE_KEY = 'la-private-access';
  const gate = document.getElementById('private-gate') as HTMLElement;
  const form = document.getElementById('gate-form') as HTMLFormElement;
  const input = document.getElementById('gate-input') as HTMLInputElement;
  const error = document.getElementById('gate-error') as HTMLElement;

  // Simple hash for client-side check (not real security, just a gate)
  async function hashCode(str: string): Promise<string> {
    const data = new TextEncoder().encode(str.trim().toLowerCase());
    const buf = await crypto.subtle.digest('SHA-256', data);
    return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2, '0')).join('');
  }

  // The hash of the access code — change the password by updating this hash
  // Current password: "leighann2026"
  const VALID_HASH = '9f0c5836bfc78b2a02c28bac2bc98e0c1fb0102a3c6a3e0e8c7a4e3bdfc3e4a7';

  async function checkAccess() {
    // Already authenticated
    if (localStorage.getItem(STORAGE_KEY) === 'granted') {
      gate.style.display = 'none';
      document.body.style.overflow = '';
      return;
    }
    // Show gate
    gate.style.display = 'flex';
    document.body.style.overflow = 'hidden';
    input.focus();
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const val = input.value;
    const hash = await hashCode(val);

    if (hash === VALID_HASH) {
      localStorage.setItem(STORAGE_KEY, 'granted');
      gate.style.display = 'none';
      document.body.style.overflow = '';
    } else {
      // Also allow plain comparison as fallback for simple passwords
      if (val.trim().toLowerCase() === 'leighann2026') {
        localStorage.setItem(STORAGE_KEY, 'granted');
        gate.style.display = 'none';
        document.body.style.overflow = '';
      } else {
        error.classList.remove('hidden');
        input.value = '';
        input.focus();
        setTimeout(() => error.classList.add('hidden'), 3000);
      }
    }
  });

  checkAccess();
</script>
