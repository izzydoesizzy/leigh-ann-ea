---
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const privatePages = [
  {
    label: "Dashboard",
    href: `${base}private`,
    match: /\/private\/?$/,
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>`,
  },
  {
    label: "Brag Sheet",
    href: `${base}private/brag-sheet`,
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.196-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118L2.098 10.1c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.518-4.674z"/></svg>`,
  },
  {
    label: "Case Study Questions",
    href: `${base}private/case-study-questions`,
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  },
  {
    label: "Getting Started",
    href: `${base}private/getting-started`,
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>`,
  },
  {
    label: "Prospects",
    href: `${base}private/prospects`,
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`,
  },
  {
    label: "Outreach",
    href: `${base}private/outreach`,
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
  },
  {
    label: "Opportunities",
    href: `${base}private/opportunities`,
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
  },
  {
    label: "Recommendations",
    href: `${base}private/recommendations`,
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>`,
  },
  {
    label: "Interview Prep",
    href: `${base}private/interview-prep`,
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>`,
  },
  {
    label: "Research",
    href: `${base}private/research`,
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
  },
];

function isActive(page: typeof privatePages[0]): boolean {
  if ('match' in page && page.match) {
    return (page.match as RegExp).test(currentPath);
  }
  const slug = page.href.replace(base, '').replace(/\/$/, '');
  return currentPath.includes(slug.split('/').pop() || '');
}
---

<!-- Desktop Sidebar -->
<aside class="hidden md:flex fixed top-0 left-0 w-60 h-screen bg-primary flex-col z-50">
  <!-- Brand -->
  <div class="px-5 pt-6 pb-4 border-b border-white/[0.08]">
    <a href={base} class="font-serif text-lg text-white/70 hover:text-white/90 transition-colors leading-tight block">
      Leigh-Ann Martin
    </a>
    <span class="text-secondary text-[10px] font-semibold tracking-[0.2em] uppercase mt-1 block">Private Toolkit</span>
  </div>

  <!-- Nav -->
  <nav class="flex-1 overflow-y-auto py-4 px-3 space-y-0.5">
    {privatePages.map(page => (
      <a
        href={page.href}
        class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm transition-all ${
          isActive(page)
            ? 'bg-white/10 text-white border-l-2 border-secondary ml-0 pl-[10px]'
            : 'text-white/45 hover:text-white/75 hover:bg-white/[0.04] border-l-2 border-transparent ml-0 pl-[10px]'
        }`}
      >
        <span class={`flex-shrink-0 ${isActive(page) ? 'text-secondary' : ''}`}>
          <Fragment set:html={page.icon} />
        </span>
        <span class="truncate">{page.label}</span>
      </a>
    ))}
  </nav>

  <!-- Footer -->
  <div class="px-5 py-4 border-t border-white/[0.08]">
    <a href={base} class="text-white/25 text-xs hover:text-white/50 transition-colors">
      &larr; Back to public site
    </a>
  </div>
</aside>

<!-- Mobile Top Bar -->
<header class="md:hidden fixed top-0 left-0 right-0 z-50 bg-primary/95 backdrop-blur-lg shadow-sm">
  <nav class="px-5 flex items-center justify-between h-14">
    <div class="flex items-center gap-2.5">
      <a href={base} class="font-serif text-lg text-white/60 hover:text-white/80 transition-colors">Leigh-Ann Martin</a>
      <span class="text-secondary text-[10px] font-semibold tracking-[0.15em] uppercase">Private</span>
    </div>
    <button id="private-mobile-menu-btn" class="text-white/60 hover:text-white transition-colors p-1" aria-label="Toggle menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </nav>
</header>

<!-- Mobile Slide-Out Overlay -->
<div id="private-mobile-overlay" class="md:hidden fixed inset-0 z-[60] hidden">
  <!-- Backdrop -->
  <div id="private-mobile-backdrop" class="absolute inset-0 bg-black/50"></div>

  <!-- Drawer -->
  <aside id="private-mobile-drawer" class="absolute top-0 left-0 w-72 h-full bg-primary shadow-2xl flex flex-col transform -translate-x-full transition-transform duration-300">
    <!-- Drawer header -->
    <div class="px-5 pt-6 pb-4 border-b border-white/[0.08] flex items-start justify-between">
      <div>
        <span class="font-serif text-lg text-white/70 block leading-tight">Leigh-Ann Martin</span>
        <span class="text-secondary text-[10px] font-semibold tracking-[0.2em] uppercase mt-1 block">Private Toolkit</span>
      </div>
      <button id="private-mobile-close" class="text-white/40 hover:text-white/70 transition-colors p-1 -mr-1 mt-0.5" aria-label="Close menu">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Drawer nav -->
    <nav class="flex-1 overflow-y-auto py-4 px-3 space-y-0.5">
      {privatePages.map(page => (
        <a
          href={page.href}
          class={`flex items-center gap-3 px-3 py-3 rounded-lg text-sm transition-all ${
            isActive(page)
              ? 'bg-white/10 text-white border-l-2 border-secondary pl-[10px]'
              : 'text-white/45 hover:text-white/75 hover:bg-white/[0.04] border-l-2 border-transparent pl-[10px]'
          }`}
        >
          <span class={`flex-shrink-0 ${isActive(page) ? 'text-secondary' : ''}`}>
            <Fragment set:html={page.icon} />
          </span>
          <span>{page.label}</span>
        </a>
      ))}
    </nav>

    <!-- Drawer footer -->
    <div class="px-5 py-4 border-t border-white/[0.08]">
      <a href={base} class="text-white/25 text-xs hover:text-white/50 transition-colors">
        &larr; Back to public site
      </a>
    </div>
  </aside>
</div>

<!-- Password Gate -->
<div id="private-gate" class="fixed inset-0 z-[100] bg-primary flex items-center justify-center">
  <div class="max-w-sm w-full mx-6 text-center">
    <div class="w-12 h-12 bg-secondary/10 rounded-full flex items-center justify-center mx-auto mb-6">
      <svg class="w-6 h-6 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
    </div>
    <p class="font-serif text-xl text-white mb-2">Private Section</p>
    <p class="text-white/40 text-sm mb-6">Enter the access code to continue.</p>
    <form id="gate-form" class="space-y-3">
      <input
        id="gate-input"
        type="password"
        placeholder="Access code"
        autocomplete="off"
        class="w-full bg-white/10 border border-white/15 rounded-full px-5 py-3 text-white text-sm text-center placeholder-white/30 focus:outline-none focus:border-secondary/50 focus:ring-1 focus:ring-secondary/30 transition-all"
      />
      <button
        type="submit"
        class="w-full bg-secondary text-white px-5 py-3 rounded-full text-sm font-semibold hover:bg-secondary/90 transition-all"
      >
        Enter
      </button>
    </form>
    <p id="gate-error" class="text-red-400 text-xs mt-3 hidden">Incorrect code. Try again.</p>
  </div>
</div>

<script>
  // ── Mobile menu ─────────────────────────────────────────────
  const menuBtn = document.getElementById('private-mobile-menu-btn');
  const overlay = document.getElementById('private-mobile-overlay');
  const backdrop = document.getElementById('private-mobile-backdrop');
  const drawer = document.getElementById('private-mobile-drawer');
  const closeBtn = document.getElementById('private-mobile-close');

  function openDrawer() {
    overlay?.classList.remove('hidden');
    requestAnimationFrame(() => {
      drawer?.classList.remove('-translate-x-full');
    });
  }

  function closeDrawer() {
    drawer?.classList.add('-translate-x-full');
    setTimeout(() => {
      overlay?.classList.add('hidden');
    }, 300);
  }

  menuBtn?.addEventListener('click', openDrawer);
  closeBtn?.addEventListener('click', closeDrawer);
  backdrop?.addEventListener('click', closeDrawer);

  // ── Password gate ──────────────────────────────────────────
  const STORAGE_KEY = 'la-private-access';
  const gate = document.getElementById('private-gate') as HTMLElement;
  const form = document.getElementById('gate-form') as HTMLFormElement;
  const input = document.getElementById('gate-input') as HTMLInputElement;
  const error = document.getElementById('gate-error') as HTMLElement;

  async function hashCode(str: string): Promise<string> {
    const data = new TextEncoder().encode(str.trim().toLowerCase());
    const buf = await crypto.subtle.digest('SHA-256', data);
    return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2, '0')).join('');
  }

  const VALID_HASH = '9f0c5836bfc78b2a02c28bac2bc98e0c1fb0102a3c6a3e0e8c7a4e3bdfc3e4a7';

  async function checkAccess() {
    if (localStorage.getItem(STORAGE_KEY) === 'granted') {
      gate.style.display = 'none';
      document.body.style.overflow = '';
      return;
    }
    gate.style.display = 'flex';
    document.body.style.overflow = 'hidden';
    input.focus();
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const val = input.value;
    const hash = await hashCode(val);

    if (hash === VALID_HASH || val.trim().toLowerCase() === 'leighann2026') {
      localStorage.setItem(STORAGE_KEY, 'granted');
      gate.style.display = 'none';
      document.body.style.overflow = '';
    } else {
      error.classList.remove('hidden');
      input.value = '';
      input.focus();
      setTimeout(() => error.classList.add('hidden'), 3000);
    }
  });

  checkAccess();
</script>
