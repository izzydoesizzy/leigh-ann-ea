<section class="py-16 md:py-24 bg-warm">
  <div class="max-w-5xl mx-auto px-6">
    <div class="text-center mb-12" data-reveal>
      <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-secondary mb-4">Industry Depth</p>
      <h2 class="font-serif text-3xl md:text-4xl text-primary leading-tight">
        Regulated industries. High-stakes environments. That's where I operate.
      </h2>
      <p class="text-text-muted text-base mt-4 max-w-2xl mx-auto">
        Every industry I've worked in has one thing in common: compliance matters, confidentiality is non-negotiable, and the cost of operational mistakes is real.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6" data-reveal-stagger>
      <!-- Biotech & Pharma -->
      <div class="bg-white rounded-2xl shadow-sm border border-primary/[0.06] p-7">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-secondary/10 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
