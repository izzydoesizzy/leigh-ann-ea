---
---

<section class="py-16 md:py-24 bg-primary">
  <div class="max-w-4xl mx-auto px-6">
    <div class="text-center mb-12" data-reveal>
      <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-secondary mb-4">Why Fractional</p>
      <h2 class="font-serif text-3xl md:text-4xl text-white leading-tight">
        Not a VA. Not a full-time hire. A strategic operator.
      </h2>
    </div>

    <div class="overflow-x-auto" data-reveal>
      <table class="w-full text-sm">
        <thead>
          <tr>
            <th class="text-left text-white/40 font-medium pb-4 pr-4"></th>
            <th class="text-left text-white/40 font-medium pb-4 px-4">VA / Agency</th>
            <th class="text-left text-white/40 font-medium pb-4 px-4">Full-Time EA</th>
            <th class="text-left pb-4 px-4">
              <span class="text-secondary font-semibold">Fractional Partner</span>
            </th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-t border-white/[0.08]">
            <td class="text-white/60 font-medium py-4 pr-4">Strategic capability</td>
            <td class="text-white/40 py-4 px-4">Task execution</td>
            <td class="text-white/40 py-4 px-4">Depends on hire</td>
            <td class="text-white py-4 px-4 font-medium">Built-in, day one</td>
          </tr>
          <tr class="border-t border-white/[0.08]">
            <td class="text-white/60 font-medium py-4 pr-4">Monthly cost</td>
            <td class="text-white/40 py-4 px-4">$2-4K</td>
            <td class="text-white/40 py-4 px-4">$10K+ (salary + benefits)</td>
            <td class="text-white py-4 px-4 font-medium">$5-12.5K, no overhead</td>
          </tr>
          <tr class="border-t border-white/[0.08]">
            <td class="text-white/60 font-medium py-4 pr-4">Ramp-up time</td>
            <td class="text-white/40 py-4 px-4">Weeks of training</td>
            <td class="text-white/40 py-4 px-4">3-6 months</td>
            <td class="text-white py-4 px-4 font-medium">30 days or less</td>
          </tr>
          <tr class="border-t border-white/[0.08]">
            <td class="text-white/60 font-medium py-4 pr-4">Board-level experience</td>
            <td class="text-white/40 py-4 px-4">Rarely</td>
            <td class="text-white/40 py-4 px-4">Maybe</td>
            <td class="text-white py-4 px-4 font-medium">12 years of it</td>
          </tr>
          <tr class="border-t border-white/[0.08]">
            <td class="text-white/60 font-medium py-4 pr-4">Risk</td>
            <td class="text-white/40 py-4 px-4">High turnover</td>
            <td class="text-white/40 py-4 px-4">Bad hire = 6-month setback</td>
            <td class="text-white py-4 px-4 font-medium">Proven operator, flexible terms</td>
          </tr>
          <tr class="border-t border-white/[0.08]">
            <td class="text-white/60 font-medium py-4 pr-4">Confidentiality</td>
            <td class="text-white/40 py-4 px-4">Varies widely</td>
            <td class="text-white/40 py-4 px-4">Internal policies</td>
            <td class="text-white py-4 px-4 font-medium">NDA from day one</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>
