---
const base = import.meta.env.BASE_URL;
---

<section class="py-10 bg-secondary/5 border-y border-secondary/10">
  <div class="max-w-4xl mx-auto px-6">
    <p class="text-secondary text-xs font-bold tracking-[0.2em] uppercase text-center mb-6">Is This You?</p>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
      <div class="bg-white rounded-xl p-4 shadow-sm border border-primary/[0.06] flex items-start gap-3">
        <svg class="w-5 h-5 text-secondary mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
        <p class="text-primary text-sm font-medium">Your EA just left and you're drowning in logistics</p>
      </div>
      <div class="bg-white rounded-xl p-4 shadow-sm border border-primary/[0.06] flex items-start gap-3">
        <svg class="w-5 h-5 text-secondary mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
        <p class="text-primary text-sm font-medium">You're weeks from a board meeting and nothing is prepped</p>
      </div>
      <div class="bg-white rounded-xl p-4 shadow-sm border border-primary/[0.06] flex items-start gap-3">
        <svg class="w-5 h-5 text-secondary mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
        <p class="text-primary text-sm font-medium">You just raised a round and need operational infrastructure yesterday</p>
      </div>
      <div class="bg-white rounded-xl p-4 shadow-sm border border-primary/[0.06] flex items-start gap-3">
        <svg class="w-5 h-5 text-secondary mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
        <p class="text-primary text-sm font-medium">You're the CEO, COO, and EA all at once</p>
      </div>
      <div class="bg-white rounded-xl p-4 shadow-sm border border-primary/[0.06] flex items-start gap-3">
        <svg class="w-5 h-5 text-secondary mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
        <p class="text-primary text-sm font-medium">Your investors are asking questions you don't have organized answers for</p>
      </div>
      <div class="bg-white rounded-xl p-4 shadow-sm border border-secondary/20 border-dashed flex items-center justify-center">
        <a href={`${base}contact`} class="text-secondary text-sm font-semibold hover:underline">Let's fix it &rarr;</a>
      </div>
    </div>
  </div>
</section>
