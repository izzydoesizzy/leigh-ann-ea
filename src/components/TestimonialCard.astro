---
interface Props {
  quote: string;
  attribution: string;
  context?: string;
}

const { quote, attribution, context } = Astro.props;
---

<div class="bg-white rounded-2xl shadow-sm border border-primary/[0.06] p-8">
  <svg class="w-8 h-8 text-secondary/30 mb-4" fill="currentColor" viewBox="0 0 24 24">
    <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z"/>
  </svg>
  <p class="text-text/80 text-[15px] leading-relaxed mb-4 italic">
    "{quote}"
  </p>
  <div>
    <p class="font-semibold text-primary text-sm">{attribution}</p>
    {context && <p class="text-text-muted text-xs mt-0.5">{context}</p>}
  </div>
</div>
